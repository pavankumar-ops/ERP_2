@model IEnumerable<ERP_Placement.Models.Test>

    @{
         Layout = "~/Views/Shared/Student_Layout.cshtml";
    }
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<style>
    body {
        background: #f4f6fb;
        font-family: 'Segoe UI', sans-serif;
    }

    .page-title {
        font-weight: 800;
        color: #3b245f;
    }

    .page-subtitle {
        color: #7a6b9a;
        font-size: 15px;
    }

    .test-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        background: #fff;
        transition: .35s;
        box-shadow: 0 10px 25px rgba(59,36,95,.08);
        position: relative;
    }

        .test-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 18px 35px rgba(59,36,95,.16);
        }

        .test-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: -120%;
            width: 70%;
            height: 100%;
            background: rgba(255,255,255,.20);
            transform: skewX(-25deg);
            transition: .8s;
        }

        .test-card:hover::before {
            left: 130%;
        }

    .test-header {
        background: linear-gradient(135deg,#3b245f,#6d4db3);
        color: white;
        padding: 18px;
    }

    .badge-custom {
        background: #f1ecff;
        color: #3b245f;
        font-size: 12px;
        padding: 8px 12px;
        border-radius: 30px;
        font-weight: 600;
    }

    .btn-start {
        border-radius: 12px;
        padding: 11px;
        font-weight: 700;
        border: none;
        background: linear-gradient(135deg,#3b245f,#6d4db3);
        color: white;
        transition: .3s;
    }

        .btn-start:hover {
            background: linear-gradient(135deg,#240f33,#2d143f,#5b3fa3);
            transform: translateY(-2px);
            box-shadow: 0 12px 24px rgba(59,36,95,.25);
        }
</style>

<div class="container py-4">

    <!-- Page Heading -->
    <div class="text-center mb-5">
        <h2 class="page-title mb-2">
            <i class="bi bi-journal-code me-2"></i>
            Available Technical Tests
        </h2>

        <p class="page-subtitle mb-0">
            Select a test and begin your technical assessment
        </p>
    </div>

    <div class="row g-4">

        @foreach (var item in Model)
        {
            <div class="col-xl-4 col-lg-4 col-md-6">

                <div class="card test-card h-100 d-flex flex-column">

                    <!-- Header -->
                    <div class="p-4 text-white"
                         style="background:linear-gradient(135deg,#2d143f,#3b245f,#6d4db3);">

                        <div class="d-flex align-items-center">

                            <div class="me-3"
                                 style="width:48px;height:48px;border-radius:12px;
                                     background:rgba(255,255,255,.15);
                                     display:flex;align-items:center;justify-content:center;">

                                <i class="bi bi-file-earmark-code fs-4"></i>

                            </div>

                            <div>
                                <h5 class="mb-0 fw-bold">@item.TestName</h5>
                                <small style="opacity:.85;">Technical Assessment</small>
                            </div>

                        </div>

                    </div>

                    <!-- Body -->
                    <div class="card-body d-flex flex-column p-4">

                        <p class="mb-3 text-dark">
                            <i class="bi bi-diagram-3-fill me-2 text-primary"></i>
                            <strong>Branch :</strong> @item.Branch
                        </p>

                        <!-- Badges -->
                        <div class="mb-4">

                            <span class="badge badge-custom me-2 mb-2">
                                <i class="bi bi-question-circle me-1"></i>20 Questions
                            </span>

                            <span class="badge badge-custom me-2 mb-2">
                                <i class="bi bi-award me-1"></i>20 Marks
                            </span>

                            <span class="badge badge-custom mb-2">
                                <i class="bi bi-clock me-1"></i>30 Min
                            </span>

                        </div>

                        <!-- Spacer -->
                        <div class="mt-auto">

                            <p class="small text-muted mb-3">
                                <strong>Test ID :</strong> @item.TestId
                            </p>

                            <a asp-controller="Student"
                               asp-action="StartTest"
                               asp-route-testId="@item.TestId"
                               class="btn btn-start w-100">

                                <i class="bi bi-play-circle me-2"></i>
                                Start Tech Test

                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>