@model IEnumerable<ERP_Placement.Models.Test>

    @{
         Layout = "~/Views/Shared/Student_Layout.cshtml";
    }
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<style>
    body {
        background: #f4f7fb;
    }

    .page-title {
        font-weight: 700;
        color: #2c3e50;
    }

    /* Card Hover Effect */
    .test-card {
        border: none;
        border-radius: 16px;
        transition: 0.3s;
        box-shadow: 0 6px 20px rgba(0,0,0,0.05);
    }

    .test-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }

    .badge-custom {
        font-size: 13px;
        padding: 6px 10px;
    }

    .btn-start {
        border-radius: 8px;
        font-weight: 600;
        padding: 10px;
        transition: 0.3s;
    }

    .btn-start:hover {
        transform: scale(1.02);
    }
</style>

<div class="container py-4">

    <div class="text-center mb-4">
        <h2 class="page-title">
            <i class="bi bi-journal-text"></i> Available Technical Tests
        </h2>
        <p class="text-muted">Select a test to begin your assessment</p>
    </div>

    <div class="row g-4">

        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6 col-sm-12">

                <div class="card test-card h-100">

                    <!-- Gradient Header -->
                    <div class="p-3 text-white"
                         style="background:linear-gradient(135deg,#6a11cb,#8e54e9); border-radius:16px 16px 0 0;">
                        <h5 class="mb-0">
                            <i class="bi bi-file-earmark-code"></i> @item.TestName
                        </h5>
                    </div>

                    <!-- Card Body -->
                    <div class="card-body">

                        <p class="mb-2">
                            <i class="bi bi-diagram-3"></i>
                            <strong>Branch :</strong> @item.Branch
                        </p>

                        <div class="mb-3">
                            <span class="badge bg-light text-dark badge-custom me-1 mb-1">
                                <i class="bi bi-question-circle"></i> 20 Questions
                            </span>

                            <span class="badge bg-light text-dark badge-custom me-1 mb-1">
                                <i class="bi bi-award"></i> 20 Marks
                            </span>

                            <span class="badge bg-light text-dark badge-custom mb-1">
                                <i class="bi bi-clock"></i> 30 Minutes
                            </span>
                        </div>

                        <p class="text-muted small mb-3">
                            Test ID : @item.TestId
                        </p>

                        <a asp-controller="Student"
                           asp-action="StartTest"
                           asp-route-testId="@item.TestId"
                           class="btn text-white w-100 btn-start"
                           style="background:linear-gradient(135deg,#6a11cb,#8e54e9); border:none; font-weight:600;">
                            <i class="bi bi-play-circle"></i> Start Tech Test
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>