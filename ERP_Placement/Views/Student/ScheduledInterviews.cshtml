@{
    ViewData["Title"] = "My Interviews";
    Layout = "~/Views/Shared/Student_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet">

<style>
    body {
        background: linear-gradient(135deg,#f8f5fc,#f2ecfa);
    }

    .page-title {
        font-weight: 700;
        color: #3b245f;
        font-size: 28px;
    }
</style>

<div class="container mt-4">

    <h4 class="page-title mb-4">My Interview Opportunities</h4>

    <div class="row g-4">

        @if (ViewBag.InterviewList != null)
        {
            foreach (System.Data.DataRow row in ViewBag.InterviewList.Rows)
            {
                var interviewTime = Convert.ToDateTime(row["InterviewTime"]).ToString("hh:mm tt");

                <div class="col-lg-4 col-md-6">

                    <div class="card shadow-sm border-0" style="border-radius:12px; overflow:hidden;">

                        <!-- Header -->
                        <div class="p-3 text-white"
                             style="background:linear-gradient(135deg,#3b245f,#6d4db3);">

                            <div class="d-flex align-items-center">

                                <img src="@row["CompanyLogo"]"
                                     style="width:55px;height:55px;border-radius:50%;object-fit:cover;background:white;padding:3px;"
                                     onerror="this.onerror=null;this.src='https://cdn-icons-png.flaticon.com/512/5968/5968705.png';" />

                                <div class="ms-3">
                                    <div style="font-size:17px;font-weight:600;">
                                        @row["JobTitle"]
                                    </div>
                                    <div style="font-size:13px;opacity:0.9;">
                                        @row["CompanyName"]
                                    </div>
                                </div>

                            </div>

                        </div>

                        <!-- Body -->
                        <div class="card-body">

                            <p class="text-muted small mb-3">
                                @row["CompanyDescription"]
                            </p>

                            <div class="mb-3">

                                <span class="badge bg-light text-dark me-1 mb-1">
                                    📍 @row["JobLocation"]
                                </span>

                                <span class="badge bg-light text-dark me-1 mb-1">
                                    💰 @row["Salary"]
                                </span>

                                <span class="badge bg-light text-dark me-1 mb-1">
                                    💼 @row["JobType"]
                                </span>

                                <span class="badge bg-info text-dark mb-1">
                                    💻 @row["InterviewType"]
                                </span>

                            </div>

                            <div class="small text-muted mb-3">

                                <div>
                                    📅 Interview :
                                    <b>@Convert.ToDateTime(row["InterviewDate"]).ToString("dd MMM yyyy")</b>
                                </div>

                                <div>
                                    ⏰ Time :
                                    <b>@interviewTime</b>
                                </div>

                                <div>
                                    🕒 Last Apply :
                                    <b>@Convert.ToDateTime(row["LastDateToApply"]).ToString("dd MMM yyyy")</b>
                                </div>

                            </div>

                            <div class="small mb-3">
                                📧 HR Email :
                                <b>@row["HREmailId"]</b>
                            </div>

                            <!-- BUTTON LOGIC -->
                            @if (row["Status"] != DBNull.Value && row["Status"].ToString() == "Assign")
                            {
                                <button class="btn w-100 text-white"
                                        style="background:linear-gradient(135deg,#3b245f,#6d4db3);border:none;font-weight:600;"
                                        onclick="ApplyInterview('@Convert.ToString(row["InterviewId"])',
                                        '@Convert.ToString(row["HREmailId"])',
                                        '@Convert.ToString(row["VacancyId"])',
                                        '@Convert.ToString(row["StudentId"])')">

                                    Apply Now
                                </button>
                            }
                            else if (row["Status"].ToString() == "Applied")
                            {
                                <button class="btn text-white w-100" disabled style="background:#6d4db3;">
                                    Applied
                                </button>
                            }
                            else if (row["Status"].ToString() == "Selected")
                            {
                                <div class="d-grid gap-2">

                                    <button class="btn text-white viewOfferBtn"
                                            style="background:#3b245f;"
                                            data-bs-toggle="modal"
                                            data-bs-target="#viewOfferModal"
                                            data-interview="@row["InterviewId"]">
                                        View Offer Letter
                                    </button>

                                    <a href="@Url.Action("DownloadOfferLetter", "Trainer", new { interviewId = row["InterviewId"] })"
                                       class="btn text-white"
                                       style="background:#6d4db3;">
                                        Download Offer Letter
                                    </a>

                                </div>
                            }

                        </div>
                    </div>

                </div>
            }
        }

    </div>
</div>

<!-- MODAL -->
<div class="modal fade" id="viewOfferModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Offer Letter</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <iframe id="offerFrame" style="width:100%; height:600px;" frameborder="0"></iframe>
            </div>

        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

<script>
    function ApplyInterview(interviewId, hrEmail, vacancyId, studentId) {

        $.ajax({
            url: '/Student/ApplyInterview',
            type: 'POST',
            data: {
                InterviewId: interviewId,
                HREmailId: hrEmail,
                VacancyId: vacancyId,
                StudentId: studentId
            },
            success: function (res) {
                if (res.success) {
                    toastr.success("Applied Successfully");
                    setTimeout(function () {
                        location.reload();
                    }, 1000);
                }
            }
        });

    }

    $(document).ready(function () {

        $(".viewOfferBtn").click(function () {

            var interviewId = $(this).data("interview");

            var url = "/Trainer/ViewOfferLetter?interviewId=" + interviewId;

            $("#offerFrame").attr("src", url);

        });

        $('#viewOfferModal').on('hidden.bs.modal', function () {
            $("#offerFrame").attr("src", "");
        });

    });
</script>