@model ERP_Placement.Models.StudentRegistration

@{
    ViewData["Title"] = "Student Enrollment";
    Layout = "~/Views/Shared/Student_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Student Dashboard</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            background-color: #f4f6f9;
        }

        .dashboard-title {
            font-weight: 600;
            color: #0d3b66;
        }

        .card-box {
            color: #fff;
            border-radius: 10px;
            padding: 20px;
            min-height: 110px;
        }

        .green {
            background: linear-gradient(45deg, #28a745, #5cd65c);
        }

        .blue {
            background: linear-gradient(45deg, #007bff, #4da3ff);
        }

        .orange {
            background: linear-gradient(45deg, #fd7e14, #ffb066);
        }

        .purple {
            background: linear-gradient(45deg, #6f42c1, #9d7df2);
        }

        .section-card {
            border-radius: 10px;
        }

        .progress-box {
            color: #fff;
            font-weight: bold;
            text-align: center;
            padding: 15px;
            border-radius: 8px;
        }
    </style>
</head>
<body>

    <div class="container my-4">

        <!-- Header -->
        <div class="text-center mb-4">
            <h3 class="dashboard-title">Placement Module - Student Dashboard</h3>
            <p class="text-muted">Welcome to your Placement Progress Overview!</p>
        </div>

        <!-- Top Cards -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card-box green">
                    <h6><i class="bi bi-check-circle"></i> Eligibility Status</h6>
                    <h5>Eligible for Placement</h5>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card-box blue">
                    <h6><i class="bi bi-briefcase"></i> Applied Jobs</h6>
                    <h3>5</h3>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card-box orange">
                    <h6><i class="bi bi-calendar-event"></i> Interviews Scheduled</h6>
                    <h3>2</h3>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card-box purple">
                    <h6><i class="bi bi-award"></i> Offers Received</h6>
                    <h3>1</h3>
                </div>
            </div>
        </div>

        <!-- Middle Section -->
        <div class="row g-3">

            <!-- Upcoming Interviews -->
            <div class="col-md-4">
                <div class="card section-card">
                    <div class="card-header fw-bold">Upcoming Interviews</div>
                    <div class="card-body">
                        <p>
                            <i class="bi bi-building"></i>
                            <strong>Tech Solutions Inc.</strong><br>
                            May 15, 2024 – 10:00 AM
                            <a class="btn btn-sm btn-primary float-end">View Details</a>
                        </p>
                        <hr>
                        <p>
                            <i class="bi bi-building"></i>
                            <strong>Global Finance Ltd.</strong><br>
                            May 18, 2024 – 2:00 PM
                            <a class="btn btn-sm btn-primary float-end">View Details</a>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Application Status -->
            <div class="col-md-4">
                <div class="card section-card">
                    <div class="card-header fw-bold">Application Status</div>
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-3">
                                <div class="progress-box green">40%</div>
                                <small>Applied</small>
                            </div>
                            <div class="col-3">
                                <div class="progress-box orange">30%</div>
                                <small>In Review</small>
                            </div>
                            <div class="col-3">
                                <div class="progress-box blue">20%</div>
                                <small>Interview</small>
                            </div>
                            <div class="col-3">
                                <div class="progress-box purple">10%</div>
                                <small>Offered</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Placement Tips -->
            <div class="col-md-4">
                <div class="card section-card">
                    <div class="card-header fw-bold">Placement Tips & Resources</div>
                    <div class="card-body">
                        <p>
                            <i class="bi bi-file-earmark-text"></i>
                            Resume Writing Guide
                            <a href="#" class="float-end">Read More</a>
                        </p>
                        <hr>
                        <p>
                            <i class="bi bi-person-video"></i>
                            Acing the Interview
                            <a href="#" class="float-end">Read More</a>
                        </p>
                        <hr>
                        <p>
                            <i class="bi bi-building"></i>
                            Company Research Tips
                            <a href="#" class="float-end">Read More</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom Section -->
        <div class="row g-3 mt-2">

            <!-- Recommended Jobs -->
            <div class="col-md-4">
                <div class="card section-card">
                    <div class="card-header fw-bold">Recommended Jobs</div>
                    <div class="card-body">
                        <p>
                            <strong>Software Developer</strong><br>
                            InnovaTech Corp
                            <a class="btn btn-sm btn-primary float-end">View Job</a>
                        </p>
                        <hr>
                        <p>
                            <strong>Marketing Analyst</strong><br>
                            BrightMark Solutions
                            <a class="btn btn-sm btn-primary float-end">View Job</a>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Offer Details -->
            <div class="col-md-8">
                <div class="card section-card">
                    <div class="card-header fw-bold">Offer Details</div>
                    <div class="card-body">
                        <h5>ABC Technologies</h5>
                        <p>
                            Position: Data Analyst<br>
                            Location: New York, NY<br>
                            Salary: $75,000 per year
                        </p>
                        <button class="btn btn-warning float-end">Confirm Offer</button>
                    </div>
                </div>
            </div>

        </div>

    </div>

</body>
</html>