@model ERP_Placement.Models.StudentRegistration

@{
    ViewData["Title"] = "Student Dashboard";
    Layout = "~/Views/Shared/Student_Layout.cshtml";

    var interviews = ViewBag.AppliedInterviews as System.Data.DataTable;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Student Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <style>

        .eligibility-popup {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg,#3b245f,#6d4db3);
            z-index: 99999;
            display: none;
            justify-content: center;
            align-items: center;
            animation: fadeIn .6s ease;
        }

        .popup-content {
            text-align: center;
            color: white;
            padding: 40px;
            animation: zoomIn .8s ease;
        }

        .success-circle {
            font-size: 90px;
            animation: bounce 1.2s infinite alternate;
        }

        .popup-title {
            font-size: 48px;
            font-weight: 800;
            margin-top: 10px;
        }

        .popup-subtitle {
            margin-top: 15px;
            font-weight: 700;
        }

        .popup-text {
            margin-top: 15px;
            font-size: 18px;
            opacity: .95;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        @@keyframes zoomIn {
            from {
                transform: scale(.5);
                opacity: 0;
            }

            to {
                transform: scale(1);
                opacity: 1;
            }
        }

        @@keyframes bounce {
            from {
                transform: translateY(0);
            }

            to {
                transform: translateY(-15px);
            }
        }

        body {
            background: radial-gradient(circle at top right, rgba(109,77,179,.10), transparent 28%), radial-gradient(circle at bottom left, rgba(59,36,95,.08), transparent 30%), linear-gradient(135deg,#eef2ff,#f8faff,#f4f6fb);
            font-family: 'Inter','Segoe UI',sans-serif;
            color: #1e293b;
        }

        /* MAIN BOX */

        .dashboard-box {
            background: rgba(255,255,255,0.92);
            padding: 22px;
            border-radius: 20px;
            border: 1px solid rgba(255,255,255,.65);
            box-shadow: 0 10px 30px rgba(15,23,42,.08), 0 2px 8px rgba(15,23,42,.04);
            backdrop-filter: blur(8px);
            transition: .3s ease;
        }

            .dashboard-box:hover {
                transform: translateY(-3px);
                box-shadow: 0 18px 40px rgba(15,23,42,.10), 0 6px 12px rgba(15,23,42,.06);
            }

        /* STAT CARD */

        .stat-card {
            position: relative;
            overflow: hidden;
            color: white;
            padding: 22px;
            border-radius: 18px;
            cursor: pointer;
            transition: all .35s ease;
            box-shadow: 0 10px 24px rgba(0,0,0,.14);
            border: 1px solid rgba(255,255,255,.15);
        }

            .stat-card::before {
                content: '';
                position: absolute;
                top: -40%;
                left: -20%;
                width: 140%;
                height: 140%;
                background: linear-gradient( 120deg, rgba(255,255,255,.18), rgba(255,255,255,0), rgba(255,255,255,.12) );
                transform: rotate(18deg);
                transition: .6s;
            }

            .stat-card:hover {
                transform: translateY(-6px) scale(1.02);
                box-shadow: 0 18px 34px rgba(0,0,0,.18);
            }

                .stat-card:hover::before {
                    left: 100%;
                }

            .stat-card h3,
            .stat-card h4,
            .stat-card h5 {
                margin: 0;
                font-weight: 700;
                letter-spacing: .4px;
            }

            .stat-card p,
            .stat-card span,
            .stat-card small {
                margin: 0;
                opacity: .95;
            }

        /* PREMIUM GRADIENTS */

        .gradient-blue {
            background: linear-gradient(135deg,#2563eb,#1d4ed8,#1e40af);
        }

        .gradient-pink {
            background: linear-gradient(135deg,#ec4899,#db2777,#be185d);
        }

        .gradient-purple {
            background: linear-gradient(135deg,#7c3aed,#6d28d9,#4c1d95);
        }

        .gradient-green {
            background: linear-gradient(135deg,#22c55e,#16a34a,#15803d);
        }

        .gradient-orange {
            background: linear-gradient(135deg,#fb923c,#f97316,#ea580c);
        }

        /* OPTIONAL NUMBER STYLE */

        .stat-number {
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 4px;
        }

        .stat-title {
            font-size: 14px;
            opacity: .95;
            letter-spacing: .3px;
        }

    </style>

</head>

<body>

    <div class="container-fluid p-4">

        <!-- HEADER -->
        <div class="mb-4">

            <h3 style="font-weight:700;">Placement Module – Student Dashboard</h3>

            <p class="text-muted">
                Welcome back
                <b>@Context.Session.GetString("StudentName")</b>
            </p>

        </div>


        <!-- TOP STATS -->
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-5 g-4">

            <div class="col d-flex">
                <div class="stat-card gradient-green w-100 h-100 d-flex flex-column justify-content-center"
                     style="cursor:pointer;"
                     onclick="showEligibilityPopup()">

                    <i class="bi bi-check-circle fs-2"></i>

                    <h5 class="mt-2">Eligibility Status</h5>

                    <h4>Eligible</h4>

                </div>
            </div>


            <div class="col d-flex">
                <div onclick="location.href='@Url.Action("AssignCompany", "Student")'"
                     class="stat-card gradient-blue w-100 h-100 d-flex flex-column justify-content-center">

                    <i class="bi bi-building fs-2"></i>

                    <h2 class="fw-bold mt-2">@ViewBag.Assign</h2>

                    <span>Assigned Companies</span>

                </div>
            </div>


            <div class="col d-flex">
                <div onclick="location.href='@Url.Action("AppliedJob", "Student")'"
                     class="stat-card gradient-orange w-100 h-100 d-flex flex-column justify-content-center">

                    <i class="bi bi-journal-text fs-2"></i>

                    <h2 class="fw-bold mt-2">@ViewBag.Applied</h2>

                    <span>Applied Jobs</span>

                </div>
            </div>


            <div class="col d-flex">
                <div onclick="location.href='@Url.Action("ScheduledInterviews", "Student")'"
                     class="stat-card gradient-purple w-100 h-100 d-flex flex-column justify-content-center">

                    <i class="bi bi-award fs-2"></i>

                    <h2 class="fw-bold mt-2">@ViewBag.Selected</h2>

                    <span>Offer Letters</span>

                </div>
            </div>


            <div class="col d-flex">

                @if (ViewBag.IsPremium == true)
                {
                    <div onclick="location.href='@Url.Action("TestList", "Student")'"
                         class="stat-card gradient-pink w-100 h-100 d-flex flex-column justify-content-center">

                        <i class="bi bi-file-earmark-text fs-2"></i>
                        <h2 class="fw-bold mt-2">@ViewBag.TestCount</h2>
                        <span>Tests</span>

                    </div>
                }
                else
                {
                    <div data-bs-toggle="modal" data-bs-target="#premiumModal"
                         class="stat-card gradient-pink w-100 h-100 d-flex flex-column justify-content-center">

                        <i class="bi bi-file-earmark-text fs-2"></i>
                        <h2 class="fw-bold mt-2">@ViewBag.TestCount</h2>
                        <span>Tests</span>

                    </div>
                }
               
            </div>
        </div>



        <!-- MIDDLE SECTION -->
        <div class="row g-4">

            <!-- UPCOMING INTERVIEWS -->
            <div class="col-lg-4">

                <div style="
            background:#fff;
            border-radius:20px;
            padding:24px;
            box-shadow:0 10px 30px rgba(59,36,95,.08);
            height:100%;">

                    <!-- Heading -->
                    <div class="d-flex justify-content-between align-items-center mb-4">

                        <h5 class="mb-0 fw-bold" style="color:#3b245f;">
                            <i class="bi bi-calendar-event me-2"></i>
                            Upcoming Interviews
                        </h5>

                        <span style="
                    background:#f1ecff;
                    color:#3b245f;
                    padding:6px 12px;
                    border-radius:30px;
                    font-size:12px;
                    font-weight:600;">
                            Schedule
                        </span>

                    </div>

                    @if (interviews != null && interviews.Rows.Count > 0)
                    {
                        foreach (System.Data.DataRow row in interviews.Rows)
                        {
                            <div style="
                                border:1px solid #eee;
                                border-radius:14px;
                                padding:14px;
                                margin-bottom:12px;
                                transition:.3s;
                                background:#faf9fd;">

                                <div class="d-flex justify-content-between align-items-center">

                                    <div>
                                        <div class="fw-bold" style="color:#3b245f;">
                                            @row["CompanyName"]
                                        </div>

                                        <small class="text-muted">
                                            <i class="bi bi-clock me-1"></i>
                                            @Convert.ToDateTime(row["InterviewTime"]).ToString("hh:mm tt")
                                        </small>
                                    </div>

                                    <span style="
                                        background:linear-gradient(135deg,#2d143f,#3b245f,#6d4db3);
                                        color:white;
                                        padding:6px 10px;
                                        border-radius:10px;
                                        font-size:12px;">
                                        @Convert.ToDateTime(row["InterviewDate"]).ToString("MMM dd")
                                    </span>

                                </div>

                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
                            No interviews scheduled
                        </div>
                    }

                </div>

            </div>



            <!-- SUCCESS RATE -->
            <div class="col-lg-4">

                <div style="
        background:#fff;
        border-radius:20px;
        padding:24px;
        box-shadow:0 10px 30px rgba(59,36,95,.08);
        height:100%;">

                    <!-- Heading -->
                    <h5 class="fw-bold mb-4" style="color:#3b245f;">
                        <i class="bi bi-bar-chart-line me-2"></i>
                        Success Rate
                    </h5>

                    <!-- Small Number -->
                    <div class="mb-3">

                        <div style="
                font-size:20px;
                font-weight:700;
                color:#3b245f;">

                            @ViewBag.SelectedPercentage%

                        </div>

                        <small class="text-muted">
                            Students Selected
                        </small>

                    </div>

                    <!-- Progress -->
                    <div class="progress"
                         style="
             height:12px;
             border-radius:30px;
             background:#ede7ff;">

                        <div class="progress-bar"
                             style="
                 width:@ViewBag.SelectedPercentage%;
                 border-radius:30px;
                 background:linear-gradient(135deg,#2d143f,#3b245f,#6d4db3);">
                        </div>

                    </div>

                    <!-- Footer Text -->
                    <div class="mt-3 text-muted small">
                        Keep improving your placement journey 🚀
                    </div>

                </div>

            </div>



            <!-- PLACEMENT TIPS -->
            <div class="col-lg-4">

                <div style="
        background:#fff;
        border-radius:20px;
        padding:24px;
        box-shadow:0 10px 30px rgba(59,36,95,.08);
        height:100%;">

                    <!-- Heading -->
                    <h5 class="fw-bold mb-4" style="color:#3b245f;">
                        <i class="bi bi-lightbulb me-2"></i>
                        Placement Tips
                    </h5>


                    <!-- Tip 1 -->
                    <div style="
            background:#faf9fd;
            border:1px solid #eee;
            border-radius:16px;
            padding:14px;
            margin-bottom:14px;">

                        <div class="d-flex justify-content-between align-items-center">

                            <div>
                                <div class="fw-semibold" style="color:#3b245f;">
                                    <i class="bi bi-file-earmark-text me-2 text-primary"></i>
                                    Resume Writing Guide
                                </div>

                                <small class="text-muted">
                                    Build ATS friendly professional resume
                                </small>
                            </div>

                            <button class="btn btn-sm text-white px-3"
                                    data-bs-toggle="modal"
                                    data-bs-target="#resumeModal"
                                    style="
                        border:none;
                        border-radius:10px;
                        background:linear-gradient(135deg,#2d143f,#3b245f,#6d4db3);
                        font-weight:600;">

                                View
                            </button>

                        </div>

                    </div>



                    <!-- Tip 2 -->
                    <div style="
            background:#faf9fd;
            border:1px solid #eee;
            border-radius:16px;
            padding:14px;
            margin-bottom:14px;">

                        <div class="d-flex justify-content-between align-items-center">

                            <div>
                                <div class="fw-semibold" style="color:#3b245f;">
                                    <i class="bi bi-person-video me-2 text-success"></i>
                                    Acing the Interview
                                </div>

                                <small class="text-muted">
                                    Crack HR + Technical interviews
                                </small>
                            </div>

                            <button class="btn btn-sm text-white px-3"
                                    data-bs-toggle="modal"
                                    data-bs-target="#interviewModal"
                                    style="
                        border:none;
                        border-radius:10px;
                        background:linear-gradient(135deg,#2d143f,#3b245f,#6d4db3);
                        font-weight:600;">

                                View

                            </button>

                        </div>

                    </div>



                    <!-- Tip 3 -->
                    <div style="
            background:#faf9fd;
            border:1px solid #eee;
            border-radius:16px;
            padding:14px;">

                        <div class="d-flex justify-content-between align-items-center">

                            <div>
                                <div class="fw-semibold" style="color:#3b245f;">
                                    <i class="bi bi-building me-2 text-warning"></i>
                                    Company Research
                                </div>

                                <small class="text-muted">
                                    Know company before interview
                                </small>
                            </div>

                            <button class="btn btn-sm text-white px-3"
                                    data-bs-toggle="modal"
                                    data-bs-target="#companyModal"
                                    style="
                        border:none;
                        border-radius:10px;
                        background:linear-gradient(135deg,#2d143f,#3b245f,#6d4db3);
                        font-weight:600;">

                                View

                            </button>

                        </div>

                    </div>

                </div>

            </div>

        </div>



        <!-- BOTTOM SECTION -->
        <div class="row g-4 mt-1">

            <!-- RECOMMENDED JOBS -->
            <div class="col-lg-4">

                <div style="
        background:#fff;
        border-radius:22px;
        padding:24px;
        box-shadow:0 12px 32px rgba(59,36,95,.08);
        height:100%;">

                    <h5 class="fw-bold mb-4" style="color:#3b245f;">
                        <i class="bi bi-briefcase-fill me-2"></i>
                        Recommended Jobs
                    </h5>

                    @if (ViewBag.AssignInterviews != null && ((System.Data.DataTable)ViewBag.AssignInterviews).Rows.Count > 0)
                    {
                        foreach (System.Data.DataRow row in ((System.Data.DataTable)ViewBag.AssignInterviews).Rows)
                        {
                            <div style="
                            border:1px solid #eee;
                            border-radius:16px;
                            padding:16px;
                            margin-bottom:14px;
                            transition:.3s;">

                                <div class="d-flex justify-content-between align-items-start">

                                    <div>
                                        <h6 class="fw-bold mb-1" style="color:#3b245f;">
                                            @row["CompanyName"]
                                        </h6>

                                        <small class="text-muted d-block mb-2">
                                            @row["JobTitle"]
                                        </small>

                                       
                                    </div>

                                    <i class="bi bi-stars fs-5" style="color:#6d4db3;"></i>

                                </div>

                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted mb-0">No jobs assigned</p>
                    }

                </div>

            </div>



            <!-- EXTRA HARD CODED CARD -->
            <div class="col-lg-2">

                <div style="
    background:#fff;
    border-radius:22px;
    padding:20px;
    box-shadow:0 12px 30px rgba(59,36,95,.08);
    height:100%;
    border:1px solid #f1eef9;">

                    <div class="text-center">

                        <div style="
            width:70px;
            height:70px;
            margin:auto;
            border-radius:50%;
            background:linear-gradient(135deg,#2d143f,#3b245f,#6d4db3);
            display:flex;
            align-items:center;
            justify-content:center;
            color:#fff;">

                            <i class="bi bi-trophy-fill fs-3"></i>

                        </div>

                        <h6 class="fw-bold mt-3 mb-1"
                            style="color:#3b245f;">

                            Career Score

                        </h6>

                        <div style="
            font-size:32px;
            font-weight:800;
            color:#6d4db3;">

                            92%

                        </div>

                        <small class="text-muted d-block mb-3">
                            Placement Ready
                        </small>

                        <div class="progress"
                             style="
                 height:10px;
                 border-radius:30px;
                 background:#ede7ff;">

                            <div class="progress-bar"
                                 style="
                     width:92%;
                     border-radius:30px;
                     background:linear-gradient(135deg,#2d143f,#3b245f,#6d4db3);">
                            </div>

                        </div>

                        <small class="d-block mt-3"
                               style="color:#6d4db3;font-weight:600;">

                            Excellent Profile

                        </small>

                    </div>

                </div>

            </div>



            <!-- OFFER DETAILS -->
            <div class="col-lg-6">

                <div style="
        background:#fff;
        border-radius:22px;
        padding:24px;
        box-shadow:0 12px 32px rgba(59,36,95,.08);
        height:100%;">

                    <h5 class="fw-bold mb-4" style="color:#3b245f;">
                        <i class="bi bi-award-fill me-2"></i>
                        Offer Details
                    </h5>

                    @if (ViewBag.OfferLetters != null && ((System.Data.DataTable)ViewBag.OfferLetters).Rows.Count > 0)
                    {
                        foreach (System.Data.DataRow row in ((System.Data.DataTable)ViewBag.OfferLetters).Rows)
                        {
                            <div style="
                            border:1px solid #f1eef9;
                            border-radius:18px;
                            padding:18px;
                            margin-bottom:16px;">

                                <div class="d-flex justify-content-between align-items-start flex-wrap">

                                    <div>
                                        <h6 class="fw-bold mb-2" style="color:#3b245f;">
                                            @row["CompanyName"]
                                        </h6>

                                        <small class="text-muted d-block">
                                            Position : @row["JobTitle"]
                                        </small>

                                        <small class="text-muted d-block">
                                            Location : @row["JobLocation"]
                                        </small>

                                        <small class="text-muted d-block">
                                            Salary : @row["Salary"]
                                        </small>
                                    </div>

                                    <div class="mt-2">

                                        <button class="btn btn-sm text-white me-2"
                                                style="
                                                background:linear-gradient(135deg,#3b245f,#6d4db3);
                                                border:none;
                                                border-radius:10px;
                                                padding:8px 14px;"
                                                onclick="viewOffer(@row["InterviewId"])">

                                            <i class="bi bi-eye-fill"></i> View

                                        </button>

                                        <a asp-controller="Student"
                                           asp-action="DownloadOfferLetter"
                                           asp-route-interviewId="@row["InterviewId"]"
                                           class="btn btn-sm text-white"
                                           style="
                                           background:linear-gradient(135deg,#16a34a,#22c55e);
                                           border:none;
                                           border-radius:10px;
                                           padding:8px 14px;">

                                            <i class="bi bi-download"></i> Download

                                        </a>

                                    </div>

                                </div>

                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted mb-0">No Offer Letters Available</p>
                    }

                </div>

            </div>

        </div>
    </div>

    <!-- MODALS -->
    <!-- Resume Modal -->
    <div class="modal fade" id="resumeModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
            <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">

                <!-- HEADER -->
                <div class="modal-header text-white"
                     style="background:linear-gradient(135deg,#3b245f,#6d4db3);">

                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-file-earmark-person-fill me-2"></i>
                        Resume Writing Guide
                    </h5>

                    <button type="button"
                            class="btn-close btn-close-white"
                            data-bs-dismiss="modal">
                    </button>
                </div>

                <!-- BODY -->
                <div class="modal-body p-4" style="background:#f8f5ff;">

                    <div class="text-center mb-4">
                        <i class="bi bi-journal-text"
                           style="font-size:45px;color:#3b245f;"></i>

                        <h4 class="fw-bold mt-2 mb-1"
                            style="color:#3b245f;">
                            Professional Resume Tips
                        </h4>

                        <small class="text-muted">
                            Build an ATS friendly & premium resume
                        </small>
                    </div>

                    <div class="row g-3">

                        <div class="col-md-6">
                            <div class="p-3 bg-white rounded-4 shadow-sm">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                Keep resume concise (1-2 pages).
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-white rounded-4 shadow-sm">
                                <i class="bi bi-person-badge-fill text-primary me-2"></i>
                                Add full name and professional title.
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-white rounded-4 shadow-sm">
                                <i class="bi bi-envelope-fill text-danger me-2"></i>
                                Use active email address.
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-white rounded-4 shadow-sm">
                                <i class="bi bi-telephone-fill text-success me-2"></i>
                                Mention mobile number clearly.
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-white rounded-4 shadow-sm">
                                <i class="bi bi-geo-alt-fill text-warning me-2"></i>
                                Add city/location only.
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-white rounded-4 shadow-sm">
                                <i class="bi bi-linkedin text-primary me-2"></i>
                                Add LinkedIn / portfolio link.
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-white rounded-4 shadow-sm">
                                <i class="bi bi-stars text-warning me-2"></i>
                                Write strong career objective.
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-white rounded-4 shadow-sm">
                                <i class="bi bi-mortarboard-fill text-info me-2"></i>
                                Mention education details properly.
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-white rounded-4 shadow-sm">
                                <i class="bi bi-code-slash text-dark me-2"></i>
                                Add technical skills clearly.
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-white rounded-4 shadow-sm">
                                <i class="bi bi-laptop-fill text-primary me-2"></i>
                                Mention projects with technologies.
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-3 bg-white rounded-4 shadow-sm">
                                <i class="bi bi-award-fill text-warning me-2"></i>
                                Add certifications if available.
                            </div>
                        </div>

                        <div class="col-md-6">
