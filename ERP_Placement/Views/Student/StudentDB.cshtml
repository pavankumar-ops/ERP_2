@model ERP_Placement.Models.StudentRegistration

@{
    ViewData["Title"] = "Student Dashboard";
    Layout = "~/Views/Shared/Student_Layout.cshtml";

    var interviews = ViewBag.AppliedInterviews as System.Data.DataTable;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Student Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <style>

        body {
            background: #f4f6fb;
            font-family: 'Inter','Segoe UI',sans-serif;
        }

        .dashboard-box {
            background: white;
            padding: 18px;
            border-radius: 16px;
            box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        }

        .stat-card {
            color: white;
            padding: 20px;
            border-radius: 14px;
            cursor: pointer;
            transition: .3s;
        }

            .stat-card:hover {
                transform: translateY(-4px);
            }

        .gradient-blue {
            background: linear-gradient(135deg,#2563eb,#1d4ed8);
        }

        .gradient-pink {
            background: linear-gradient(135deg,#ec4899,#db2777);
        }

        .gradient-purple {
            background: linear-gradient(135deg,#a855f7,#7c3aed);
        }

        .gradient-green {
            background: linear-gradient(135deg,#22c55e,#16a34a);
        }

        .gradient-orange {
            background: linear-gradient(135deg,#fb923c,#f97316);
        }

    </style>

</head>

<body>

    <div class="container-fluid p-4">

        <!-- HEADER -->
        <div class="mb-4">

            <h3 style="font-weight:700;">Placement Module – Student Dashboard</h3>

            <p class="text-muted">
                Welcome back
                <b>@Context.Session.GetString("StudentName")</b>
            </p>

        </div>


        <!-- TOP STATS -->
        <div class="row g-3 mb-4">

            <div class="col">
                <div class="stat-card gradient-green">

                    <i class="bi bi-check-circle fs-2"></i>

                    <h5 class="mt-2">Eligibility Status</h5>

                    <h4>Eligible</h4>

                </div>
            </div>


            <div class="col">
                <div onclick="location.href='@Url.Action("AssignCompany", "Student")'"
                     class="stat-card gradient-blue">

                    <i class="bi bi-building fs-2"></i>

                    <h2 class="fw-bold mt-2">@ViewBag.Assign</h2>

                    <span>Assigned Companies</span>

                </div>
            </div>


            <div class="col">
                <div onclick="location.href='@Url.Action("AppliedJob", "Student")'"
                     class="stat-card gradient-orange">

                    <i class="bi bi-journal-text fs-2"></i>

                    <h2 class="fw-bold mt-2">@ViewBag.Applied</h2>

                    <span>Applied Jobs</span>

                </div>
            </div>


            <div class="col">
                <div onclick="location.href='@Url.Action("ScheduledInterviews", "Student")'"
                     class="stat-card gradient-purple">

                    <i class="bi bi-award fs-2"></i>

                    <h2 class="fw-bold mt-2">@ViewBag.Selected</h2>

                    <span>Offer Letters</span>

                </div>
            </div>


            <div class="col">
                <div onclick="location.href='@Url.Action("TestList", "Student")'"
                     class="stat-card gradient-pink">

                    <i class="bi bi-file-earmark-text fs-2"></i>

                    <h2 class="fw-bold mt-2">@ViewBag.TestCount</h2>

                    <span>Tests</span>

                </div>
            </div>

        </div>



        <!-- MIDDLE SECTION -->
        <div class="row g-4">


            <!-- UPCOMING INTERVIEWS -->
            <div class="col-lg-4">

                <div class="dashboard-box">

                    <div class="d-flex justify-content-between mb-3">

                        <b>Upcoming Interviews</b>

                    </div>

                    @if (interviews != null && interviews.Rows.Count > 0)
                    {
                        foreach (System.Data.DataRow row in interviews.Rows)
                        {

                            <div class="border rounded p-2 mb-2 d-flex justify-content-between align-items-center">

                                <div>
                                    <b>@row["CompanyName"]</b><br>
                                    <small>@row["InterviewTime"]</small>
                                </div>

                                <small class="text-muted">
                                    @Convert.ToDateTime(row["InterviewDate"]).ToString("MMM dd")
                                </small>

                            </div>

                        }
                    }
                    else
                    {
                        <p>No interviews scheduled</p>
                    }

                </div>

            </div>



            <!-- SUCCESS RATE -->
            <div class="col-lg-4">

                <div class="dashboard-box">

                    <b>Success Rate</b>

                    <div class="mt-3">

                        <div class="progress" style="height:22px">

                            <div class="progress-bar bg-success"
                                 style="width:@ViewBag.SelectedPercentage%">

                                @ViewBag.SelectedPercentage%

                            </div>

                        </div>

                    </div>

                </div>

            </div>



            <!-- PLACEMENT TIPS -->
            <div class="col-lg-4">

                <div class="dashboard-box">

                    <b>Placement Tips</b>

                    <div class="mt-3">

                        <p>
                            <i class="bi bi-file-earmark-text text-primary"></i>
                            Resume Writing Guide
                            <span class="float-end text-primary"
                                  data-bs-toggle="modal"
                                  data-bs-target="#resumeModal">
                                Read More
                            </span>
                        </p>

                        <hr>

                        <p>
                            <i class="bi bi-person-video text-success"></i>
                            Acing the Interview
                            <span class="float-end text-primary"
                                  data-bs-toggle="modal"
                                  data-bs-target="#interviewModal">
                                Read More
                            </span>
                        </p>

                        <hr>

                        <p>
                            <i class="bi bi-building text-warning"></i>
                            Company Research
                            <span class="float-end text-primary"
                                  data-bs-toggle="modal"
                                  data-bs-target="#companyModal">
                                Read More
                            </span>
                        </p>

                    </div>

                </div>

            </div>


        </div>



        <!-- BOTTOM SECTION -->
        <div class="row g-4 mt-1">

            <!-- RECOMMENDED JOBS -->
            <div class="col-lg-4">

                <div class="dashboard-box">

                    <b>Recommended Jobs</b>

                    @if (ViewBag.AssignInterviews != null && ((System.Data.DataTable)ViewBag.AssignInterviews).Rows.Count > 0)
                    {
                        foreach (System.Data.DataRow row in ((System.Data.DataTable)ViewBag.AssignInterviews).Rows)
                        {

                            <div class="border rounded p-2 mt-2 d-flex justify-content-between">

                                <div>
                                    <b>@row["CompanyName"]</b><br>
                                    <small>@row["JobTitle"]</small>
                                </div>

                                <a class="btn btn-sm btn-primary">View Job</a>

                            </div>

                        }
                    }
                    else
                    {
                        <p class="mt-2">No jobs assigned</p>
                    }

                </div>

            </div>



            <!-- OFFER DETAILS -->
            <div class="col-lg-8">

                <div class="dashboard-box">

                    <b>Offer Details</b>

                    @if (ViewBag.OfferLetters != null && ((System.Data.DataTable)ViewBag.OfferLetters).Rows.Count > 0)
                    {

                        foreach (System.Data.DataRow row in ((System.Data.DataTable)ViewBag.OfferLetters).Rows)
                        {

                            <div class="border-bottom pb-2 mb-2">

                                <h6>@row["CompanyName"]</h6>

                                <small>

                                    Position : @row["JobTitle"] <br>
                                    Location : @row["JobLocation"] <br>
                                    Salary : @row["Salary"]

                                </small>

                                <div class="float-end">

                                    <button class="btn btn-primary btn-sm"
                                            onclick="viewOffer(@row["InterviewId"])">

                                        <i class="bi bi-eye"></i> View

                                    </button>

                                    <a asp-controller="Student"
                                       asp-action="DownloadOfferLetter"
                                       asp-route-interviewId="@row["InterviewId"]"
                                       class="btn btn-success btn-sm">

                                        <i class="bi bi-download"></i> Download

                                    </a>

                                </div>

                            </div>

                        }

                    }
                    else
                    {
                        <p>No Offer Letters Available</p>
                    }

                </div>

            </div>

        </div>

    </div>

    <!-- MODALS -->
    <!-- Resume Modal -->
    <div class="modal fade" id="resumeModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-file-earmark-text"></i> Resume Writing Guide</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <ul>
                        <li>Keep your resume concise (1-2 pages).</li>
                        <li>Highlight your achievements and skills.</li>
                        <li>Use a clean, modern format.</li>
                        <li>Tailor it for the job you are applying for.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Interview Modal -->
    <div class="modal fade" id="interviewModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-person-video"></i> Acing the Interview</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <ul>
                        <li>Research the company and the role.</li>
                        <li>Prepare answers for common interview questions.</li>
                        <li>Dress professionally and maintain good body language.</li>
                        <li>Ask insightful questions at the end of the interview.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Company Modal -->
    <div class="modal fade" id="companyModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-warning text-white">
                    <h5 class="modal-title"><i class="bi bi-building"></i> Company Research Tips</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <ul>
                        <li>Understand the company’s products and services.</li>
                        <li>Follow recent news and achievements.</li>
                        <li>Check employee reviews and company culture.</li>
                        <li>Analyze the competitors and market positioning.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Offer Letter Modal -->
    <div class="modal fade" id="offerModal" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">

                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title">Offer Letter</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body p-0">
                    <iframe id="offerFrame" width="100%" height="600" style="border:none"></iframe>
                </div>

            </div>
        </div>
    </div>

    <!-- SCRIPTS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function viewOffer(interviewId){
            var url = "/Trainer/ViewOfferLetter?interviewId=" + interviewId;
            document.getElementById("offerFrame").src = url;
            var modal = new bootstrap.Modal(document.getElementById("offerModal"));
            modal.show();
        }
    </script>

</body>
</html>