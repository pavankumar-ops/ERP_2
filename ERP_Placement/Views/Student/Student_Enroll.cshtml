<script>
    function previewProfilePhoto(event) {
        const output = document.getElementById('profilePreview');
        output.src = URL.createObjectURL(event.target.files[0]);
    }

    function removeProfilePhoto() {
        const img = document.getElementById('profilePreview');
        img.src = "https://via.placeholder.com/120";
        document.getElementById('profilePhotoInput').value = "";
    }

    //seleting the gender
     document.getElementById("nametitle").addEventListener("change", function () {
         debugger;
        const title = this.value;
        const genderSelect = document.getElementById("gender");

        if (title === "Mr") {
            genderSelect.value = "Male";
        }
        else if (title === "Ms" || title === "Mrs") {
            genderSelect.value = "Female";
        }
        
    });

    //date of birth validations
     document.addEventListener("DOMContentLoaded", function () {

        const dob = document.getElementById("dob");
        const form = dob.closest("form");

        function calculateAge(dobDate) {
            const today = new Date();
            let age = today.getFullYear() - dobDate.getFullYear();
            const m = today.getMonth() - dobDate.getMonth();
            if (m < 0 || (m === 0 && today.getDate() < dobDate.getDate())) {
                age--;
            }
            return age;
        }

        function validateDOB() {
            if (!dob.value) return true;

            const selectedDate = new Date(dob.value);
            const age = calculateAge(selectedDate);

            if (age < 18 || age > 26) {
                showToast("Student Age must be between 18 to 26");
                dob.value = "";
                dob.focus();
                return false;
            }
            return true;
        }

        // 🔥 Trigger on manual typing
        dob.addEventListener("input", validateDOB);

        // 🔥 Trigger when leaving field
        dob.addEventListener("blur", validateDOB);

        // 🔥 Trigger on submit
        form.addEventListener("submit", function (e) {
            if (!validateDOB()) {
                e.preventDefault();
            }
        });
    });


    document.addEventListener("DOMContentLoaded", function () {

        const mob = document.getElementById("mobno");

        const form = mob.closest("form");

        function isValidMobile(number) {
            return /^[6-9]\d{9}$/.test(number);
        }

        function validateMobile() {
            const value = mob.value.trim();

            if (!value) return true;

            if (!isValidMobile(value)) {
                showToast("Mobile number must valid be 10 digits");
                mob.value = "";
                mob.focus();
                return false;
            }
            return true;
        }

        // 🔹 Allow only numbers while typing
        mob.addEventListener("input", function () {
            this.value = this.value.replace(/\D/g, "");
            if (this.value.length > 10) {
                this.value = this.value.slice(0, 10);
            }
        });

        // 🔹 Validate on leaving field
        mob.addEventListener("blur", validateMobile);

        // 🔹 Validate on submit
        form.addEventListener("submit", function (e) {
            if (!validateMobile()) {
                e.preventDefault();
            }
        });
    });


    document.addEventListener("DOMContentLoaded", function () {

        const mob = document.getElementById("AlternateMobile");

        const form = mob.closest("form");

        function isValidMobile(number) {
            return /^[6-9]\d{9}$/.test(number);
        }

        function validateMobile() {
            const value = mob.value.trim();

            if (!value) return true;

            if (!isValidMobile(value)) {
                showToast("Mobile number must valid be 10 digits");
                mob.value = "";
                mob.focus();
                return false;
            }
            return true;
        }

        // 🔹 Allow only numbers while typing
        mob.addEventListener("input", function () {
            this.value = this.value.replace(/\D/g, "");
            if (this.value.length > 10) {
                this.value = this.value.slice(0, 10);
            }
        });

        // 🔹 Validate on leaving field
        mob.addEventListener("blur", validateMobile);

        // 🔹 Validate on submit
        form.addEventListener("submit", function (e) {
            if (!validateMobile()) {
                e.preventDefault();
            }
        });
    });

    function showToast(message) {

        // Remove existing toast
        const oldToast = document.getElementById("inlineToast");
        if (oldToast) oldToast.remove();

        const toast = document.createElement("div");
        toast.id = "inlineToast";
        toast.innerHTML = `
            <span style="font-size:20px;">⚠️</span>
            <span style="flex:1;">${message}</span>
        `;

        // Inline styles
        Object.assign(toast.style, {
            position: "fixed",
            top: "20px",
            right: "-400px",
            minWidth: "280px",
            maxWidth: "360px",
            padding: "14px 18px",
            background: "linear-gradient(135deg, #dc3545, #b02a37)",
            color: "#fff",
            borderRadius: "10px",
            display: "flex",
            alignItems: "center",
            gap: "12px",
            fontFamily: "Segoe UI, sans-serif",
            fontSize: "14px",
            fontWeight: "500",
            boxShadow: "0 10px 25px rgba(0,0,0,0.25)",
            zIndex: "99999",
            transition: "right 0.4s ease"
        });

        document.body.appendChild(toast);

        // Slide in
        setTimeout(() => toast.style.right = "20px", 50);

        // Slide out & remove
        setTimeout(() => {
            toast.style.right = "-400px";
            setTimeout(() => toast.remove(), 400);
        }, 3000);
    }

</script>
