<script>
    document.addEventListener("DOMContentLoaded", function () {

        const mobile = document.getElementById("mobno");
        const alternate = document.getElementById("AlternateMobile");

        function normalize(val) {
            return val.replace(/\D/g, "");
        }

        function validateNotSame(triggeredInput) {
            const mobVal = normalize(mobile.value);
            const altVal = normalize(alternate.value);

            // If one or both empty → OK
            if (!mobVal || !altVal) return true;

            // If both filled & same
            if (mobVal === altVal) {
                showToast("Mobile number and Alternate mobile number must not be the same");
                triggeredInput.value = "";
                triggeredInput.focus();
                return false;
            }
            return true;
        }

        // Allow only digits & max 10
        [mobile, alternate].forEach(input => {
            input.addEventListener("input", function () {
                this.value = normalize(this.value).slice(0, 10);
            });
        });

        // Blur validation on BOTH inputs
        mobile.addEventListener("blur", function () {
            validateNotSame(mobile);
        });

        alternate.addEventListener("blur", function () {
            validateNotSame(alternate);
        });
    });
</script>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const email = document.getElementById("emailid");
        const confirmEmail = document.getElementById("confimemailid");


        const gmailRegex = /^[a-z0-9._%+-]+@@gmail\.com$/;

        function validateGmail(input) {
            const value = input.value.trim();

            if (!value) return true;

            if (!gmailRegex.test(value)) {
                showToast("Please Entre Valid Email Id");
                input.value = "";
                input.focus();
                return false;
            }
            return true;
        }

        function validateMatch() {
            if (!email.value || !confirmEmail.value) return true;

            if (email.value !== confirmEmail.value) {
                showToast("Email and Confirm Email must be the same");
                email.value = "";
                confirmEmail.value = "";
                email.focus();
                return false;
            }
            return true;
        }

        // 🔹 Blur validation
        email.addEventListener("blur", function () {
            if (validateGmail(email)) {
                validateMatch();
            }
        });

        confirmEmail.addEventListener("blur", function () {
            if (validateGmail(confirmEmail)) {
                validateMatch();
            }
        });
    });
</script>


<script>
    document.addEventListener("DOMContentLoaded", function () {

        const roll = document.getElementById("rollno");
        const confirmRoll = document.getElementById("confirmrollno");
        const form = roll.closest("form");

        function onlyDigits(input) {
            input.value = input.value.replace(/\D/g, "").slice(0, 5);
        }

        function validateLength(input) {
            if (input.value.length > 5) {
                showToast("Roll number must be exactly 5 digits");
                input.value = "";
                input.focus();
                return false;
            }
            return true;
        }

        function validateMatch(triggeredInput) {
            if (!roll.value) return true; // 🔥 IMPORTANT RULE

            if (!confirmRoll.value) return true;

            if (roll.value !== confirmRoll.value) {
                showToast("Roll Number and Confirm Roll Number must be the same");
                roll.value = "";
                confirmRoll.value = "";
                triggeredInput.focus();
                return false;
            }
            return true;
        }

        // Allow only digits
        roll.addEventListener("input", () => onlyDigits(roll));
        confirmRoll.addEventListener("input", () => onlyDigits(confirmRoll));

        // 🔹 Roll blur
        roll.addEventListener("blur", function () {
            if (roll.value && validateLength(roll)) {
                validateMatch(roll);
            }
        });

        // 🔹 Confirm blur (BLOCKED if Roll is empty)
        confirmRoll.addEventListener("blur", function () {
            if (!roll.value) return; // 🚫 Do nothing
            if (validateLength(confirmRoll)) {
                validateMatch(confirmRoll);
            }
        });

        // 🔹 Submit validation
        form.addEventListener("submit", function (e) {
            if (!roll.value) return; // Let required validation handle it

            if (
                !validateLength(roll) ||
                !validateLength(confirmRoll) ||
                !validateMatch(roll)
            ) {
                e.preventDefault();
            }
        });
    });
</script>
<script>
    document.addEventListener("DOMContentLoaded", function () {

        const ddl = document.getElementById("sscpassingyear");
        const currentYear = new Date().getFullYear();

        const endYear = currentYear - 3;      // before 3 years
        const startYear = endYear - 9;         // total 10 years range

        for (let year = startYear; year <= endYear; year++) {
            const academicYear = `${year}-${year + 1}`;
            const option = document.createElement("option");
            option.value = academicYear;
            option.textContent = academicYear;
            ddl.appendChild(option);
        }
    });
</script>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const ssc = document.getElementById("sscpercentage");
        const form = ssc.closest("form");

        function validateSSC() {
            const value = ssc.value.trim();

            if (!value) return true; // empty allowed (required handled elsewhere)

            const marks = Number(value);

            // Not a number OR out of range
            if (isNaN(marks) || marks < 0 || marks > 100) {
                showToast("SSC percentage less 100");
                ssc.value = "";
                ssc.focus();
                return false;
            }

            // Passing marks check
            if (marks < 35) {
                showToast("SSC percentage must be 35% or above (Passing marks)");
                ssc.value = "";
                ssc.focus();
                return false;
            }

            return true;
        }

        // 🔹 Allow only numbers & decimal (optional)
        ssc.addEventListener("input", function () {
            this.value = this.value.replace(/[^0-9.]/g, "");

            // allow only one decimal point
            if ((this.value.match(/\./g) || []).length > 1) {
                this.value = this.value.slice(0, -1);
            }
        });

        // 🔹 Blur validation
        ssc.addEventListener("blur", validateSSC);

        // 🔹 Submit validation
        form.addEventListener("submit", function (e) {
            if (!validateSSC()) {
                e.preventDefault();
            }
        });
    });
</script>

<script>
    function validateProfilePhoto(input) {

        if (!input.files || !input.files[0]) return;

        const file = input.files[0];

        const allowedTypes = ["image/jpeg", "image/png"];
        const maxSize = 1 * 1024 * 1024; // 1 MB

        // ❌ Invalid format
        if (!allowedTypes.includes(file.type)) {
            showToast("Only JPG or PNG image formats are allowed");
            input.value = "";
            return;
        }

        // ❌ File too large
        if (file.size > maxSize) {
            showToast("Profile photo size must be less than 1 MB");
            input.value = "";
            return;
        }

        // ✅ Optional: preview image if valid
        previewProfilePhoto({ target: input });
    }
</script>


<script>
    function validateSSCMarksheet(input) {

        if (!input.files || !input.files[0]) return;

        const file = input.files[0];

        const allowedTypes = [
            "application/pdf",
            "image/jpeg",
            "image/png"
        ];

        const maxSize = 2 * 1024 * 1024; // 2 MB

        // ❌ Invalid file type
        if (!allowedTypes.includes(file.type)) {
            showToast("Only PDF, JPG, JPEG or PNG files are allowed for SSC marksheet");
            input.value = "";
            return;
        }

        // ❌ File size exceeded
        if (file.size > maxSize) {
            showToast("SSC marksheet file size must not exceed 2 MB");
            input.value = "";
            return;
        }

        // ✅ Valid file → do nothing
    }
</script>


