<script>
    document.addEventListener("DOMContentLoaded", function () {

        const fields = [
            { id: "sscpercentage", label: "SSC" },
            { id: "hscpercentage", label: "HSC" },
            { id: "diplomapercentage", label: "Diploma" },
            { id: "btechpercentage", label: "B.Tech" }
        ];

        const form = document.getElementById("sscpercentage").closest("form");

        function validatePercentage(input, label) {
            const value = input.value.trim();

            // Empty allowed (required handled separately)
            if (!value) return true;

            const marks = Number(value);

            if (isNaN(marks) || marks < 0 || marks > 100) {
                showToast(`${label} percentage must be between 0 and 100`);
                input.value = "";
                input.focus();
                return false;
            }

            if (marks < 35) {
                showToast(`${label} percentage must be 35% or above (Passing marks)`);
                input.value = "";
                input.focus();
                return false;
            }

            return true;
        }

        fields.forEach(field => {
            const input = document.getElementById(field.id);

            // 🔹 Allow only numbers + single decimal
            input.addEventListener("input", function () {
                this.value = this.value.replace(/[^0-9.]/g, "");

                if ((this.value.match(/\./g) || []).length > 1) {
                    this.value = this.value.slice(0, -1);
                }
            });

            // 🔹 Blur validation
            input.addEventListener("blur", function () {
                validatePercentage(input, field.label);
            });
        });

        // 🔹 Submit validation (checks all 4)
        form.addEventListener("submit", function (e) {
            for (let field of fields) {
                const input = document.getElementById(field.id);
                if (!validatePercentage(input, field.label)) {
                    e.preventDefault();
                    return;
                }
            }
        });

    });
</script>

<script>
    function validateProfilePhoto(input) {

        if (!input.files || !input.files[0]) return;

        const file = input.files[0];

        const allowedTypes = ["image/jpeg", "image/png"];
        const maxSize = 1 * 1024 * 1024; // 1 MB

        // ❌ Invalid format
        if (!allowedTypes.includes(file.type)) {
            showToast("Only JPG or PNG image formats are allowed");
            input.value = "";
            return;
        }

        // ❌ File too large
        if (file.size > maxSize) {
            showToast("Profile photo size must be less than 1 MB");
            input.value = "";
            return;
        }

        // ✅ Optional: preview image if valid
        previewProfilePhoto({ target: input });
    }
</script>


