                        <input asp-for="MiddleName"
                               type="text"
                               class="form-control border-dark"
                               pattern="[A-Za-z ]+"
                               maxlength="50"
                               inputmode="text"
                               oninput="this.value=this.value.replace(/[^A-Za-z ]/g,'')"
                               required />
                    </div>

                    <div class="col-md-3">
                        <label asp-for="LastName" class="form-label">Last Name</label>
                        <input asp-for="LastName"
                               type="text"
                               class="form-control border-dark"
                               pattern="[A-Za-z ]+"
                               maxlength="50"
                               inputmode="text"
                               oninput="this.value=this.value.replace(/[^A-Za-z ]/g,'')"
                               required />
