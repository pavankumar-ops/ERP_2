<script>
    function toggleEducation() {
        const selected = document.querySelector('input[name="EduType"]:checked').value;

        const hsc = document.getElementById("hscSection");
        const diploma = document.getElementById("diplomaSection");

        // Hide both first
        hsc.style.display = "none";
        diploma.style.display = "none";

        if (selected === "HSC") {
            hsc.style.display = "block";
        }
        else if (selected === "Diploma") {
            diploma.style.display = "block";
        }
        else if (selected === "Both") {
            hsc.style.display = "block";
            diploma.style.display = "block";
        }
    }
</script>

