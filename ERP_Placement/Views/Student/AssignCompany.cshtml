@{
    ViewData["Title"] = "My Interviews";
    Layout = "~/Views/Shared/Student_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet">

<style>

    body {
        background: #f5f7fa;
        font-family: 'Segoe UI',sans-serif;
    }

    .page-title {
        font-weight: 700;
        color: #2c3e50;
    }

    .job-card {
        border: none;
        border-radius: 12px;
        background: white;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

        .job-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        }

    .company-logo {
        width: 55px;
        height: 55px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #eee;
    }

    .job-title {
        font-size: 17px;
        font-weight: 600;
        color: #34495e;
    }

    .company-name {
        font-size: 14px;
        color: #7f8c8d;
    }

    .job-desc {
        font-size: 13px;
        color: #555;
        height: 40px;
        overflow: hidden;
    }

    .badge-custom {
        background: #ecf0f1;
        color: #34495e;
        font-size: 12px;
        padding: 6px 10px;
        border-radius: 20px;
        margin-right: 5px;
    }

    .apply-btn {
        background: #0d6efd;
        border: none;
        border-radius: 8px;
        font-weight: 600;
    }

        .apply-btn:hover {
            background: #084298;
        }

    .hr-mail {
        font-size: 13px;
    }

    .success-checkmark {
        width: 80px;
        height: 80px;
        margin: auto;
    }

    .check-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        border: 4px solid #28a745;
        position: relative;
    }

    .icon-line {
        height: 5px;
        background: #28a745;
        position: absolute;
        border-radius: 2px;
    }

    .line-tip {
        top: 46px;
        left: 14px;
        width: 25px;
        transform: rotate(45deg);
    }

    .line-long {
        top: 38px;
        right: 8px;
        width: 47px;
        transform: rotate(-45deg);
    }

</style>

<div class="container mt-4">

    <h4 class="page-title mb-4">My Interview Opportunities</h4>

    <div class="row g-4">

        @if (ViewBag.InterviewList != null)
        {
            foreach (System.Data.DataRow row in ViewBag.InterviewList.Rows)
            {
                var interviewTime = Convert.ToDateTime(row["InterviewTime"]).ToString("hh:mm tt");

                <div class="col-lg-4 col-md-6">

                    <div class="card shadow-sm border-0" style="border-radius:12px; overflow:hidden;">

                        <!-- Gradient Header -->
                        <div class="p-3 text-white"
                             style="background:linear-gradient(135deg,#3b245f,#6d4db3);">

                            <div class="d-flex align-items-center">

                                <img src="@row["CompanyLogo"]"
                                     class="me-3"
                                     style="width:55px;height:55px;border-radius:50%;object-fit:cover;background:white;padding:3px;"
                                     onerror="this.onerror=null;this.src='https://cdn-icons-png.flaticon.com/512/5968/5968705.png';" />

                                <div>

                                    <div style="font-size:17px;font-weight:600;">
                                        @row["JobTitle"]
                                    </div>

                                    <div style="font-size:13px;opacity:0.9;">
                                        @row["CompanyName"]
                                    </div>

                                </div>

                            </div>

                        </div>


                        <!-- Card Body -->
                        <div class="card-body">

                            <!-- Description -->
                            <p class="text-muted small mb-3" style="height:40px;overflow:hidden;">
                                @row["CompanyDescription"]
                            </p>


                            <!-- Job Tags -->
                            <div class="mb-3">

                                <span class="badge bg-light text-dark me-1 mb-1">
                                    📍 @row["JobLocation"]
                                </span>

                                <span class="badge bg-light text-dark me-1 mb-1">
                                    💰 @row["Salary"]
                                </span>

                                <span class="badge bg-light text-dark me-1 mb-1">
                                    💼 @row["JobType"]
                                </span>

                                <span class="badge bg-info text-dark mb-1">
                                    💻 @row["InterviewType"]
                                </span>

                            </div>


                            <!-- Interview Info -->
                            <div class="small text-muted mb-3">

                                <div>
                                    📅 Interview :
                                    <b>@Convert.ToDateTime(row["InterviewDate"]).ToString("dd MMM yyyy")</b>
                                </div>

                                <div>
                                    ⏰ Time :
                                    <b>@interviewTime</b>
                                </div>

                                <div>
                                    🕒 Last Apply :
                                    <b>@Convert.ToDateTime(row["LastDateToApply"]).ToString("dd MMM yyyy")</b>
                                </div>

                            </div>


                            <!-- HR Email -->
                            <div class="small mb-3">
                                📧 HR Email :
                                <b>@row["HREmailId"]</b>
                            </div>


                            <!-- Buttons -->
                            @if (row["Status"].ToString()=="Assign")
                            {

                                <button class="btn w-100 text-white"
                                        style="background:linear-gradient(135deg,#3b245f,#6d4db3);;border:none;font-weight:600;"
                                        onclick="ApplyInterview('@row["InterviewId"]','@row["HREmailId"]','@row["VacancyId"]','@row["StudentId"]')">

                                    Apply Now

                                </button>

                            }
                            else if (row["Status"].ToString()=="Applied")
                            {

                                <button class="btn btn-secondary w-100" disabled>
                                    Applied
                                </button>

                            }
                            else if (row["Status"].ToString()=="Selected")
                            {

                                <div class="d-grid gap-2">

                                    <button class="btn btn-info"
                                            data-bs-toggle="modal"
                                            data-bs-target="#viewOfferModal">

                                        View Offer Letter

                                    </button>

                                    <a href="@Url.Action("DownloadOfferLetter", "Trainer", new { interviewId = row["InterviewId"] })"
                                       class="btn btn-primary">

                                        Download Offer Letter

                                    </a>

                                </div>

                            }

                        </div>

                    </div>

                </div>

            }
        }

    </div>

</div>

<!-- SUCCESS MODAL -->

<div class="modal fade" id="successModal" tabindex="-1">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content text-center p-4">

            <div class="modal-body">

                <div class="success-checkmark">



                    <div style="font-size:60px;color:#28a745;">
                        ✔
                    </div>



                </div>

                <h4 class="text-success mt-3">Success</h4>

                <p id="successMessage"></p>

                <button class="btn btn-success mt-2" data-bs-dismiss="modal" onclick="refreshPage()">
                    OK
                </button>

            </div>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

<script>

    function ApplyInterview(interviewId,hrEmail,vacancyId,studentId){

    $.ajax({

    url:'/Student/ApplyInterview',

    type:'POST',

    data:{
    InterviewId:interviewId,
    HREmailId:hrEmail,
    VacancyId:vacancyId,
    StudentId:studentId
    },

    success:function(res){

    if(res.success){

    $("#successMessage").text(res.message);

    var modal = new bootstrap.Modal(document.getElementById('successModal'));

    modal.show();

    toastr.success(res.message);

    }

    }

    })

    }


        function refreshPage() {
        location.reload();
    }
</script>