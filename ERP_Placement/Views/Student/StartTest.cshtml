@model IEnumerable<ERP_Placement.Models.Test>

    @{
         Layout = "~/Views/Shared/Student_Layout.cshtml";
    }

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>

    body {
        background: #f4f7fb;
    }

    .test-header {
        background: linear-gradient(135deg,#4e73df,#224abe);
        color: white;
        border-radius: 12px;
    }

    .question-card {
        border: none;
        border-radius: 12px;
        transition: .3s;
    }

        .question-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(0,0,0,.1);
        }

    .option-btn {
        width: 100%;
        text-align: left;
        border: 1px solid #e2e6ea;
        border-radius: 8px;
        padding: 10px;
        background: white;
        transition: .25s;
    }

        .option-btn:hover {
            background: #eef3ff;
            border-color: #4e73df;
        }

        .option-btn.selected {
            background: #4e73df;
            color: white;
            border-color: #4e73df;
        }

    .timer {
        font-size: 22px;
        font-weight: bold;
        color: #dc3545;
    }

    .submit-btn {
        padding: 12px 50px;
        font-size: 18px;
        border-radius: 30px;
    }

</style>

<div class="container mt-4">

    <!-- TIMER -->
    <div class="row justify-content-center mb-3">
        <div class="col-lg-10">

            <div class="card shadow-sm text-center">

                <div class="card-body">

                    <h5>Time Remaining</h5>
                    <div class="timer" id="timer">30:00</div>

                    <!-- Progress Bar -->
                    <div class="progress mt-3" style="height:10px;">
                        <div id="progressBar"
                             class="progress-bar bg-danger"
                             style="width:100%">
                        </div>
                    </div>

                </div>

            </div>

        </div>
    </div>


    <div class="row justify-content-center">

        <div class="col-lg-10">

            <!-- HEADER -->
            <div class="card test-header shadow mb-4">
                <div class="card-body text-center">

                    <h2 class="fw-bold">Technical Test</h2>
                    <p>Select the correct answer</p>

                </div>
            </div>


            <form method="post" asp-action="StartTest" id="testForm">

                <input type="hidden" name="testId" value="@Model.First().TestId" />

                @foreach (var q in Model)
                {

                    <div class="card question-card shadow-sm mb-4">

                        <div class="card-body">

                            <h5 class="fw-semibold mb-3">

                                <span class="badge bg-primary me-2">
                                    Q @q.QuestionNo
                                </span>

                                @q.Question

                            </h5>

                            <div class="row">

                                <div class="col-md-6 mb-2">

                                    <button type="button"
                                            class="option-btn"
                                            onclick="selectAnswer(this,'q_@q.QuestionId','A')">

                                        <strong>A.</strong> @q.OptionA

                                    </button>

                                </div>

                                <div class="col-md-6 mb-2">

                                    <button type="button"
                                            class="option-btn"
                                            onclick="selectAnswer(this,'q_@q.QuestionId','B')">

                                        <strong>B.</strong> @q.OptionB

                                    </button>

                                </div>

                                <div class="col-md-6 mb-2">

                                    <button type="button"
                                            class="option-btn"
                                            onclick="selectAnswer(this,'q_@q.QuestionId','C')">

                                        <strong>C.</strong> @q.OptionC

                                    </button>

                                </div>

                                <div class="col-md-6 mb-2">

                                    <button type="button"
                                            class="option-btn"
                                            onclick="selectAnswer(this,'q_@q.QuestionId','D')">

                                        <strong>D.</strong> @q.OptionD

                                    </button>

                                </div>

                            </div>

                            <!-- Hidden input -->
                            <input type="hidden" name="q_@q.QuestionId" />

                        </div>

                    </div>

                }

                <div class="text-center mb-5">

                    <button type="submit" class="btn btn-success submit-btn">
                        Submit Test
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>

    let totalTime = 30 * 60;
    let time = totalTime;

    let timer = setInterval(function () {

        let minutes = Math.floor(time / 60);
        let seconds = time % 60;

        seconds = seconds < 10 ? "0" + seconds : seconds;

        document.getElementById("timer").innerHTML = minutes + ":" + seconds;

        // progress bar
        let percent = (time / totalTime) * 100;
        document.getElementById("progressBar").style.width = percent + "%";

        time--;

        if (time < 0) {

            clearInterval(timer);

            // AUTO SUBMIT
            document.getElementById("testForm").submit();

        }

    }, 1000);



    function selectAnswer(btn, name, value) {

        let container = btn.closest(".row");

        container.querySelectorAll(".option-btn").forEach(function (b) {
            b.classList.remove("selected");
        });

        btn.classList.add("selected");

        let hiddenInput = btn.closest(".card-body").querySelector("input[name='" + name + "']");
        hiddenInput.value = value;

    }

</script>