@model IEnumerable<ERP_Placement.Models.Test>

    @{
         Layout = "~/Views/Shared/Student_Layout.cshtml";
    }

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />


<style>

    body {
        background: #f4f6fb;
        font-family: 'Segoe UI',sans-serif;
    }

    /* TEST HEADER */
    .test-header {
        background: linear-gradient(135deg,#3b245f,#6d4db3);
        color: #fff;
        border: none;
        border-radius: 18px;
        box-shadow: 0 12px 30px rgba(59,36,95,.15);
    }

    /* TIMER CARD */
    .timer-card {
        border: none;
        border-radius: 18px;
        background: #fff;
        box-shadow: 0 10px 25px rgba(59,36,95,.08);
    }

    .timer {
        font-size: 28px;
        font-weight: 700;
        color: #3b245f;
    }

    /* PROGRESS */
    .progress {
        height: 10px;
        border-radius: 20px;
        background: #ede7ff;
    }

    .progress-bar {
        background: linear-gradient(135deg,#3b245f,#6d4db3);
        border-radius: 20px;
    }

    /* QUESTION CARD */
    .question-card {
        border: none;
        border-radius: 18px;
        background: #fff;
        box-shadow: 0 10px 28px rgba(59,36,95,.08);
        transition: .3s;
    }

        .question-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 18px 35px rgba(59,36,95,.14);
        }

        /* QUESTION BADGE */
        .question-card .badge {
            background: #ede7ff !important;
            color: #3b245f !important;
            border-radius: 30px;
            padding: 8px 14px;
            font-size: 13px;
        }

    /* OPTION BUTTON */
    .option-btn {
        width: 100%;
        text-align: left;
        padding: 12px 15px;
        border: 1px solid #e5dcff;
        border-radius: 14px;
        background: #fff;
        color: #3b245f;
        font-weight: 500;
        transition: .25s;
    }

        .option-btn:hover {
            background: #f6f2ff;
            border-color: #6d4db3;
            transform: translateY(-2px);
        }

        .option-btn.selected {
            background: linear-gradient(135deg,#3b245f,#6d4db3);
            color: #fff;
            border-color: transparent;
            box-shadow: 0 10px 22px rgba(59,36,95,.18);
        }

    /* SUBMIT BUTTON */
    .submit-btn {
        padding: 14px 55px;
        border: none;
        border-radius: 40px;
        background: linear-gradient(135deg,#3b245f,#6d4db3);
        color: #fff;
        font-size: 18px;
        font-weight: 700;
        transition: .3s;
    }

        .submit-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(59,36,95,.20);
        }

</style>

<div class="container mt-4">

    <!-- TIMER -->
    <div class="row justify-content-center mb-3">
        <div class="col-lg-10">

            <div class="card shadow-sm text-center">

                <div class="card-body">

                    <h5>Time Remaining</h5>
                    <div class="timer" id="timer">30:00</div>

                    <!-- Progress Bar -->
                    <div class="progress mt-3" style="height:10px;">
                        <div id="progressBar"
                             class="progress-bar bg-danger"
                             style="width:100%">
                        </div>
                    </div>

                </div>

            </div>

        </div>
    </div>


    <div class="row justify-content-center">

        <div class="col-lg-10">

            <!-- HEADER -->
            <div class="card test-header shadow mb-4">
                <div class="card-body text-center">

                    <h2 class="fw-bold">Technical Test</h2>
                    <p>Select the correct answer</p>

                </div>
            </div>


            <form method="post" asp-action="StartTest" id="testForm">

                <input type="hidden" name="testId" value="@Model.First().TestId" />

                @foreach (var q in Model)
                {

                    <div class="card question-card shadow-sm mb-4">

                        <div class="card-body">

                            <h5 class="fw-semibold mb-3">

                                <span class="badge bg-primary me-2">
                                    Q @q.QuestionNo
                                </span>

                                @q.Question

                            </h5>

                            <div class="row">

                                <div class="col-md-6 mb-2">

                                    <button type="button"
                                            class="option-btn"
                                            onclick="selectAnswer(this,'q_@q.QuestionId','A')">

                                        <strong>A.</strong> @q.OptionA

                                    </button>

                                </div>

                                <div class="col-md-6 mb-2">

                                    <button type="button"
                                            class="option-btn"
                                            onclick="selectAnswer(this,'q_@q.QuestionId','B')">

                                        <strong>B.</strong> @q.OptionB

                                    </button>

                                </div>

                                <div class="col-md-6 mb-2">

                                    <button type="button"
                                            class="option-btn"
                                            onclick="selectAnswer(this,'q_@q.QuestionId','C')">

                                        <strong>C.</strong> @q.OptionC

                                    </button>

                                </div>

                                <div class="col-md-6 mb-2">

                                    <button type="button"
                                            class="option-btn"
                                            onclick="selectAnswer(this,'q_@q.QuestionId','D')">

                                        <strong>D.</strong> @q.OptionD

                                    </button>

                                </div>

                            </div>

                            <!-- Hidden input -->
                            <input type="hidden" name="q_@q.QuestionId" />

                        </div>

                    </div>

                }

                <div class="text-center mb-5">

                    <button type="submit" class="btn btn-success submit-btn">
                        Submit Test
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>

    let totalTime = 30 * 60;
    let time = totalTime;

    let timer = setInterval(function () {

        let minutes = Math.floor(time / 60);
        let seconds = time % 60;

        seconds = seconds < 10 ? "0" + seconds : seconds;

        document.getElementById("timer").innerHTML = minutes + ":" + seconds;

        // progress bar
        let percent = (time / totalTime) * 100;
        document.getElementById("progressBar").style.width = percent + "%";

        time--;

        if (time < 0) {

            clearInterval(timer);

            // AUTO SUBMIT
            document.getElementById("testForm").submit();

        }

    }, 1000);



    function selectAnswer(btn, name, value) {

        let container = btn.closest(".row");

        container.querySelectorAll(".option-btn").forEach(function (b) {
            b.classList.remove("selected");
        });

        btn.classList.add("selected");

        let hiddenInput = btn.closest(".card-body").querySelector("input[name='" + name + "']");
        hiddenInput.value = value;

    }

</script>