@model ERP_Placement.Models.login_Properties
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Forgot Password</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #DDCCE6;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-container {
            background: #fff;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
            max-width: 1100px;
            width: 100%;
        }

        .side-box {
            background: #f0f4ff;
            border-radius: 15px;
            padding: 40px;
        }

        .login-title {
            font-size: 28px;
            font-weight: 600;
        }

        .form-control {
            height: 48px;
            border-radius: 8px;
        }

        .btn-primary {
            background-color: #5367F5;
            height: 48px;
            border-radius: 8px;
            font-size: 16px;
        }

        .timer {
            font-size: 14px;
            color: red;
        }

        .password-rules {
            font-size: 13px;
            color: #6c757d;
        }
    </style>
</head>

<body>

    <div class="container login-container p-4">
        <div class="row g-0">

            <!-- LEFT SIDE -->
            <div class="col-lg-6 p-5">

                <h3 class="login-title mb-4">Forgot Password</h3>

                <!-- STEP 1 -->
                <div id="step1Card">

                    
                    <!-- Email + Send OTP -->
                    <div class="row mb-2">
                        <div class="col-8">
                            <input type="email"
                                   id="email"
                                   
                                   class="form-control"
                                   placeholder="Enter Registered Email">
                        </div>
                        <div class="col-4">
                            <button id="otpBtn"
                                    class="btn btn-primary w-100"
                                        onclick="generateOTP()">
                                Send OTP
                            </button>
                        </div>
                    </div>
                    

                    <div id="timer" class="timer mb-3"></div>

                    <!-- Enter OTP -->
                    <div class="mb-3">
                        <input type="text"
                               id="otp"
                               class="form-control"
                               placeholder="Enter OTP">
                    </div>

                    <div class="mb-4">
                        <button class="btn btn-primary w-100"
                                onclick="verifyOTP()">
                            Verify OTP
                        </button>
                    </div>

                </div>

                <!-- STEP 2 (Hidden Initially) -->
                <div id="step2Card" style="display:none;">

                    <!-- New Password -->
                    <div class="mb-3">
                        <input type="password"
                               id="newPassword"
                               class="form-control"
                               placeholder="Enter New Password"
                               onkeyup="checkPasswordStrength()">

                        <div class="password-rules">
                            Must contain 8+ chars, uppercase, lowercase, number & special character.
                        </div>
                    </div>

                    <!-- Confirm Password -->
                    <div class="mb-4">
                        <input type="password"
                               id="confirmPassword"
                               class="form-control"
                               placeholder="Confirm New Password">
                    </div>

                    <div class="row">
                        <div class="col-6">
                            <button class="btn btn-primary w-100"
                                    onclick="updatePassword()">
                                Update Password
                            </button>
                        </div>
                        <div class="col-6">
                            <a href="@Url.Action("Login", "Login")"
                               class="btn btn-outline-primary w-100">
                                Back to Log In
                            </a>
                        </div>
                    </div>

                </div>
                <div id="message" class="mt-3 text-success"></div>
                <div class="d-flex justify-content-between align-items-center mb-4">
              
                    <a href="#" class="text-primary">Back to Log In ?</a>
                </div>
                

            </div>

            <!-- RIGHT SIDE -->
            <div class="col-lg-6 side-box text-center">

                <img src="~/img/login/woman using laptop to explain login steps tutorial vector illustration-hd.jpg"
                     style="width: 90%;
                        height: auto;
                        max-width: 420px;
                        max-height: 380px;
                        object-fit: contain;
                        display: block;
                        margin: 0 auto 20px auto;" />

            </div>

        </div>
    </div>

    <script>

        let countdown;

        // 60 SECOND TIMER
        function startTimer(seconds) {

            let timeLeft = seconds;
            let btn = document.getElementById("otpBtn");
            let timerDiv = document.getElementById("timer");

            btn.disabled = true;

            countdown = setInterval(function () {

                timerDiv.innerHTML = "Resend OTP in " + timeLeft + " seconds";
                timeLeft--;

                if (timeLeft < 0) {
                    clearInterval(countdown);
                    timerDiv.innerHTML = "";
                    btn.disabled = false;
                }

            }, 1000);
        }

        // SEND OTP
   

        // VERIFY OTP
               function verifyOTP() {

            var email = $("#email").val();
            var otp = $("#otp").val();

            if (otp == "") {
                alert("Please enter OTP");
                return;
            }

            $.ajax({
                url: '/Login/VerifyOTP',
                type: 'POST',
                data: {
                    email: email,
                    otp: otp
                },
                success: function (response) {

                    if (response.success) {

                        $("#step1Card").hide();
                        $("#step2Card").show();
                        $("#message").html("OTP verified successfully.");

                    } else {

                        alert(response.message);
                    }
                },
                error: function () {
                    alert("Something went wrong");
                }
            });
        }

        // STRONG PASSWORD CHECK
        function checkPasswordStrength() {

            var password = document.getElementById("newPassword").value;
            var regex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@@$!%*?&]).{8,}$/;

            if (!regex.test(password)) {
                document.getElementById("newPassword").style.borderColor = "red";
            } else {
                document.getElementById("newPassword").style.borderColor = "green";
            }
        }

        // UPDATE PASSWORD
              function updatePassword() {

            var email = $("#email").val(); // IMPORTANT
            var newPassword = $("#newPassword").val();
            var confirmPassword = $("#confirmPassword").val();

            if (newPassword !== confirmPassword) {
                alert("Passwords do not match");
                return;
            }

            $.ajax({
                url: '/Login/ResetPassword',
                type: 'POST',
                data: {
                    email: email,
                    newPassword: newPassword
                },
                success: function (response) {

                    if (response.success) {

                       alert("Password updated successfully!");

                         window.location.href = '/Login/Student_LoginPage';


                    } else {

                        alert(response.message);
                    }
                },
                error: function () {
                    alert("Something went wrong");
                }
            });
        }

                   function generateOTP() {
                       debugger;
            var email = $("#email").val();

            if (email == "") {
                alert("Please enter email");
                return;
            }

            $.ajax({
                url: '/Login/SendOTP',
                type: 'POST',
                data: { email: email },   // ✅ this sends properly to MVC
                success: function (response) {

                    if (response.success) {

                        startTimer(60);
                        $("#message").html("OTP sent successfully.");

                    } else {

                        alert(response.message);
                    }
                },
                error: function () {
                    alert("Something went wrong");
                }
            });
        }
            

    </script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</body>
</html>