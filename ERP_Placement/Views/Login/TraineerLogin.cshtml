@model ERP_Placement.Models.login_Properties

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modern Login</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f7f9fc;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-container {
            background: #fff;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
            max-width: 1100px;
            width: 100%;
        }

        .side-box {
            background: #f0f4ff;
            border-radius: 15px;
            padding: 40px;
        }

            .side-box img {
                width: 100%;
                border-radius: 10px;
            }

        .login-title {
            font-size: 28px;
            font-weight: 600;
        }

        .form-control {
            height: 48px;
            border-radius: 8px;
        }

        .btn-primary {
            background-color: #5367F5;
            height: 48px;
            border-radius: 8px;
            font-size: 16px;
        }

        .google-btn {
            border-radius: 8px;
            height: 48px;
        }
    </style>
</head>

<body style="background: #DDCCE6">

    <div class="container login-container p-4">
        <div class="row g-0">

            <!-- LEFT: Login Form -->
            <div class="col-lg-6 p-5">


                <h3 class="login-title mb-3">Sign in</h3>

                

                <form method="post" action="/Login/Stud_Login">

                    <div class="mb-3">
                        <input type="text" class="form-control" placeholder="Username or Email" asp-for="UserId">
                    </div>

                    <div class="mb-3">
                        <input type="password" class="form-control" placeholder="Password" asp-for="Password">
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="remember">
                            <label class="form-check-label" for="remember">
                                Remember Me
                            </label>
                        </div>
                        <a href="#" class="text-primary">Forgot Password?</a>
                    </div>

                    <button class="btn btn-primary w-100">Log In</button>


                </form>

            </div>

            <!-- RIGHT: Banner / Carousel -->
            <div class="col-lg-6 side-box text-center">

                <img src="~/img/login/woman using laptop to explain login steps tutorial vector illustration-hd.jpg"
                     style="
        width: 90%;
        height: auto;
        max-width: 420px;
        max-height: 380px;
        object-fit: contain;
        display: block;
        margin: 0 auto 20px auto;
     " />

                @*  <h4 class="mt-4 fw-bold">Placement ERA</h4>
                <p>
                    Placement ERA is an advanced automation platform that makes difficult tasks simple and helps improve productivity with ease
                </p>

                <button class="btn btn-outline-primary rounded-pill px-4 mt-2">
                    Learn More →
                </button>

                <div class="mt-4 fs-5 text-primary">
                    • • •
                </div>
 *@
            </div>

        </div>
    </div>

</body>
</html>


