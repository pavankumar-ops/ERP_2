<style>


    .branch-header {
        background: linear-gradient(135deg,#6a11cb,#2575fc,#ff6a00);
        background-size: 400% 400%;
        animation: gradientMove 10s ease infinite;
        color: white;
        padding: 25px;
        border-radius: 12px;
    }

    @@keyframes gradientMove {
        0%

    {
        background-position: 0% 50%
    }

    50% {
        background-position: 100% 50%
    }

    100% {
        background-position: 0% 50%
    }

    }

    .recruiter-logo {
        height: 40px;
        filter: grayscale(100%);
        transition: 0.3s;
    }

        .recruiter-logo:hover {
            filter: none;
            transform: scale(1.1);
        }

    .timeline {
        border-left: 3px solid #0d6efd;
        padding-left: 20px;
    }

    .timeline-item {
        margin-bottom: 20px;
    }

    .student-card img {
        height: 160px;
        object-fit: cover;
    }
    .hero-image {
        object-fit: cover;
        height: 380px;
    }

    .course-card:hover {
        transform: translateY(-5px);
    }


    .placement-section .card-img-top {
        width: 100%;
        height: 200px; /* FIXED HEIGHT for all images */
        object-fit: contain; /* Show FULL IMAGE without cutting */
        background: #f0f0f0; /* Light background for empty space */
        padding: 5px; /* Gives clean border spacing */
    }

    .placement-section .card {
        height: 100%; /* All cards equal height */
        border-radius: 10px;
    }

    .custom-card {
        background-color: #d6c1f0; /* soft light purple */
        color: #3b245f;
    }




    .comapny.slider {
        overflow: hidden;
        position: relative;
        width: 100%;
    }

    .comapny .slide-track {
        display: flex;
        animation: scroll 25s linear infinite;
        width: calc(200px * 12); /* MUST MATCH TOTAL LOGOS */
    }

    .comapny .slide {
        height: 100px;
        width: 200px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

        .comapny .slide img {
            width: 140px;
            height: auto;
            object-fit: contain;
        }

    /* Slider Animation */
    @@keyframes scroll {
        0% {
            transform: translateX(0);
        }

        100% {
            transform: translateX(-50%);
        }
    }

</style>
