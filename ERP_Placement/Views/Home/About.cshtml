@{
    ViewBag.Title = "About Student Module";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<style>

    body {
        background: #f5f7fb;
    }

    /* HERO */

    .hero {
        background: linear-gradient(135deg,#5f2c82,#49a09d);
        color: white;
        padding: 90px 30px;
        border-radius: 15px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

        .hero h1 {
            font-weight: 700;
            font-size: 42px;
        }

    /* ABOUT IMAGE */

    .about-img {
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    /* FEATURE CARDS */

    .feature-card {
        border: none;
        border-radius: 15px;
        padding: 30px;
        background: white;
        transition: 0.4s;
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
    }

        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 12px 35px rgba(0,0,0,0.2);
        }

    .feature-icon {
        font-size: 45px;
        color: #5f2c82;
    }

    /* STATS */

    .stat-card {
        border-radius: 15px;
        padding: 30px;
        text-align: center;
        background: white;
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
        transition: 0.3s;
    }

        .stat-card:hover {
            background: #5f2c82;
            color: white;
        }

    /* TEAM */

    .team-card {
        border: none;
        border-radius: 15px;
        text-align: center;
        padding: 25px;
        background: white;
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
        transition: 0.4s;
    }

        .team-card:hover {
            transform: scale(1.05);
        }

    .team-img {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 50%;
        border: 4px solid #5f2c82;
    }

    /* CONTACT */

    .contact-box {
        background: white;
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
    }

    .section-title {
        font-weight: 700;
        margin-bottom: 20px;
    }

</style>



    <!-- HERO SECTION -->

<div class="container-fluid px-4">
    <div class="hero mb-5">

        <h1><i class="bi bi-mortarboard-fill"></i> Student Placement Portal</h1>

        <p class="lead mt-3">
            A digital platform designed to simplify campus placements
            and help students connect with top companies.
        </p>

    </div>
</div>




    <!-- ABOUT -->

    <div class="row align-items-center mb-5">

        <div class="col-md-6">

            <img src="https://images.unsplash.com/photo-1523240795612-9a054b0db644"
                 class="img-fluid about-img"
                 alt="Students Placement">

        </div>

        <div class="col-md-6">

            <h3 class="section-title text-primary">About the Student Module</h3>

            <p>
                The Student Module of the ERP Placement System helps students
                manage their entire placement journey from a single platform.
            </p>

            <p>
                Students can view company job openings, upload resumes,
                track interview schedules, and download offer letters.
            </p>

            <p>
                The portal improves transparency and communication
                between students and placement coordinators.
            </p>

        </div>

    </div>



    <!-- FEATURES -->

    <div class="text-center mb-4">

        <h2 class="section-title">Student Features</h2>

        <p class="text-muted">
            Everything students need during placements
        </p>

    </div>


    <div class="row g-4 mb-5">

        <div class="col-md-4">
            <div class="feature-card text-center">
                <i class="bi bi-building feature-icon"></i>
                <h5 class="mt-3">Company Listings</h5>
                <p class="text-muted">
                    Explore companies participating in campus placements.
                </p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="feature-card text-center">
                <i class="bi bi-calendar-event feature-icon"></i>
                <h5 class="mt-3">Interview Schedule</h5>
                <p class="text-muted">
                    Check upcoming interview dates and details.
                </p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="feature-card text-center">
                <i class="bi bi-file-earmark-person feature-icon"></i>
                <h5 class="mt-3">Resume Upload</h5>
                <p class="text-muted">
                    Upload and manage your resume for recruiters.
                </p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="feature-card text-center">
                <i class="bi bi-envelope-paper feature-icon"></i>
                <h5 class="mt-3">Offer Letters</h5>
                <p class="text-muted">
                    Download offer letters after company selection.
                </p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="feature-card text-center">
                <i class="bi bi-bell feature-icon"></i>
                <h5 class="mt-3">Notifications</h5>
                <p class="text-muted">
                    Stay updated with placement announcements.
                </p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="feature-card text-center">
                <i class="bi bi-person-check feature-icon"></i>
                <h5 class="mt-3">Application Tracking</h5>
                <p class="text-muted">
                    Track job applications and interview status.
                </p>
            </div>
        </div>

    </div>



    <!-- STATISTICS -->

    <div class="text-center mb-4">

        <h2 class="section-title">Placement Statistics</h2>

    </div>


    <div class="row g-4 text-center mb-5">

        <div class="col-md-3">
            <div class="stat-card">
                <h2>250+</h2>
                <p>Students Placed</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <h2>60+</h2>
                <p>Companies</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <h2>320+</h2>
                <p>Job Offers</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <h2>96%</h2>
                <p>Success Rate</p>
            </div>
        </div>

    </div>



    <!-- TEAM -->

    <div class="text-center mb-4">

        <h2 class="section-title">Project Team</h2>

        <p class="text-muted">
            Meet the team behind the ERP Placement System
        </p>

    </div>


    <div class="row g-4 mb-5">

        <!-- GUIDE -->

        <div class="col-md-3">

            <div class="team-card">

                <img src="https://randomuser.me/api/portraits/men/45.jpg"
                     class="team-img mb-3">

                <h5>Dr. Rajesh Sharma</h5>

                <p class="text-muted">Project Guide</p>

            </div>

        </div>



        <!-- DEVELOPER 1 -->

        <div class="col-md-3">

            <div class="team-card">

                <img src="https://randomuser.me/api/portraits/men/32.jpg"
                     class="team-img mb-3">

                <h5>Tanmay Shinde</h5>

                <p class="text-muted">Full Stack Developer</p>

            </div>

        </div>



        <!-- DEVELOPER 2 -->

        <div class="col-md-3">

            <div class="team-card">

                <img src="https://randomuser.me/api/portraits/women/44.jpg"
                     class="team-img mb-3">

                <h5>Sneha Patil</h5>

                <p class="text-muted">Frontend Developer</p>

            </div>

        </div>



        <!-- DEVELOPER 3 -->

        <div class="col-md-3">

            <div class="team-card">

                <img src="https://randomuser.me/api/portraits/men/76.jpg"
                     class="team-img mb-3">

                <h5>Amit Verma</h5>

                <p class="text-muted">Backend Developer</p>

            </div>

        </div>

    </div>



    <!-- CONTACT -->

    <div class="contact-box text-center mb-5">

        <h4 class="text-primary">Need Assistance?</h4>

        <p class="text-muted">
            For placement related queries please contact the placement cell.
        </p>

        <p class="fw-bold">

            <i class="bi bi-envelope"></i> placement@college.com

        </p>

    </div>
