<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Floating Placement Chatbot</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
        }

        /* FLOATING ICON */
        .chatbot-icon {
            position: fixed;
            bottom: 25px;
            right: 25px;
            background: #0d6efd;
            color: #fff;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            font-size: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 6px 20px rgba(0,0,0,.25);
            z-index: 9999;
        }

        /* CHAT WINDOW */
        .chatbot-box {
            position: fixed;
            bottom: 100px;
            right: 25px;
            width: 350px;
            height: 480px;
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,.3);
            display: none;
            flex-direction: column;
            z-index: 9999;
        }

        /* HEADER */
        .chat-header {
            background: #0d6efd;
            color: #fff;
            padding: 14px;
            font-weight: 600;
            border-radius: 16px 16px 0 0;
            display: flex;
            justify-content: space-between;
        }

        /* BODY */
        .chat-body {
            flex: 1;
            padding: 12px;
            overflow-y: auto;
            background: #f8f9fa;
        }

        /* FOOTER FAQ */
        .chat-footer {
            padding: 10px;
            border-top: 1px solid #ddd;
            background: #fff;
        }

        .faq-btn {
            width: 100%;
            border: 1px solid #0d6efd;
            color: #0d6efd;
            border-radius: 20px;
            font-size: 13px;
            margin-bottom: 6px;
        }

            .faq-btn:hover {
                background: #0d6efd;
                color: #fff;
            }

        /* CHAT MESSAGES */
        .bot-msg, .user-msg {
            max-width: 85%;
            padding: 10px 14px;
            border-radius: 14px;
            margin-bottom: 8px;
            font-size: 13px;
        }

        .bot-msg {
            background: #e9ecef;
        }

        .user-msg {
            background: #0d6efd;
            color: #fff;
            margin-left: auto;
            text-align: right;
        }
    </style>
</head>
<body>

    <!-- FLOATING ICON -->
    <div class="chatbot-icon" onclick="toggleChat()">💬</div>

    <!-- CHAT BOX -->
    <div class="chatbot-box" id="chatBox">

        <div class="chat-header">
            🤖 Placement Bot
            <span style="cursor:pointer;" onclick="toggleChat()">✖</span>
        </div>

        <div class="chat-body" id="chatBody">
            <div class="bot-msg">
                Hi 👋 <br>
                I’m your Placement Assistant.
                Select a question below 👇
            </div>
        </div>

        <div class="chat-footer">
            <button class="btn faq-btn" onclick="sendFAQ(1)">Placement Process</button>
            <button class="btn faq-btn" onclick="sendFAQ(2)">Eligible Branches</button>
            <button class="btn faq-btn" onclick="sendFAQ(3)">Resume Guidelines</button>
            <button class="btn faq-btn" onclick="sendFAQ(4)">Interview Schedule</button>
            <button class="btn faq-btn" onclick="sendFAQ(5)">Contact Placement Cell</button>
        </div>
    </div>

    <script>
        const chatBox = document.getElementById("chatBox");
        const chatBody = document.getElementById("chatBody");

        const faqAnswers = {
            1: "Placement process includes registration, aptitude test, technical interview, HR round, and final offer.",
            2: "Eligible branches depend on company criteria. Mostly CSE, IT, ENTC, Mechanical & Electrical.",
            3: "Resume must be one page, updated, error-free, and approved by placement coordinator.",
            4: "Interview schedules are shared via ERP notifications and official emails.",
            5: "Placement Cell Contact: placement@college.edu | Room No. 12"
        };

        function toggleChat(){
            chatBox.style.display = chatBox.style.display === "flex" ? "none" : "flex";
        }

        function sendFAQ(id){
            const question = document.querySelectorAll(".faq-btn")[id-1].innerText;

            const userDiv = document.createElement("div");
            userDiv.className = "user-msg";
            userDiv.innerText = question;
            chatBody.appendChild(userDiv);

            setTimeout(()=>{
                const botDiv = document.createElement("div");
                botDiv.className = "bot-msg";
                botDiv.innerText = faqAnswers[id];
                chatBody.appendChild(botDiv);
                chatBody.scrollTop = chatBody.scrollHeight;
            },300);
        }
    </script>

</body>
</html>