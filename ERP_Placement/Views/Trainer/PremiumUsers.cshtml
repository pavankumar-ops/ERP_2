@model System.Data.DataTable

@{
    ViewData["Title"] = "Payment List";
    Layout = "~/Views/Shared/Placement_Coordinator_layout.cshtml";
}

<!DOCTYPE html>

<html>

<head>

    <title>Payment List</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>

        body {
            font-family: 'Segoe UI';
            background: #f4f6fb;
            color: #3b245f;
        }

        .page-header {
            background: linear-gradient(135deg,#3b245f,#6d4db3);
            padding: 16px 24px;
            border-radius: 14px;
            color: white;
            margin-bottom: 25px;
            box-shadow: 0 8px 22px rgba(0,0,0,0.15);
        }

        .payment-card {
            border: none;
            border-radius: 18px;
            overflow: hidden;
            transition: .3s;
            background: white;
        }

            .payment-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 12px 28px rgba(0,0,0,0.18);
            }

        .card-strip {
            height: 50px;
            background: linear-gradient(135deg,#3b245f,#6d4db3);
        }

        .student-photo {
            width: 85px;
            height: 85px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid white;
            margin-top: -42px;
        }

        .student-name {
            font-size: 18px;
            font-weight: 700;
            color: #3b245f;
        }

        .info-text {
            font-size: 14px;
            margin-bottom: 6px;
        }

        .status-badge {
            padding: 8px 15px;
            border-radius: 20px;
            font-size: 12px;
            display: inline-block;
        }

        .paid {
            background: #28a745;
            color: white;
        }

        .pending {
            background: #ffc107;
            color: black;
        }

        .amount-box {
            background: #f5f1ff;
            border-radius: 12px;
            padding: 10px;
            margin-top: 10px;
        }

        .amount {
            font-size: 24px;
            font-weight: 700;
            color: #3b245f;
        }

        .download-btn {
            background: linear-gradient(135deg,#3b245f,#6d4db3);
            color: white;
            border: none;
            border-radius: 12px;
            padding: 10px;
            font-size: 14px;
            font-weight: 600;
            transition: 0.3s;
            box-shadow: 0 6px 16px rgba(59,36,95,0.25);
            text-decoration: none;
            display: block;
        }

            .download-btn:hover {
                transform: translateY(-2px);
                color: white;
                box-shadow: 0 8px 20px rgba(59,36,95,0.35);
            }

    </style>

</head>

<body>

    <div class="page-header">

        <h4 class="mb-0">
            <i class="bi bi-credit-card-2-front-fill me-2"></i>
            Payment List
        </h4>

    </div>

    <div class="row">

        @if (Model != null && Model.Rows.Count > 0)
        {
            foreach (System.Data.DataRow row in Model.Rows)
            {
                var status = row["Status"].ToString();

                <div class="col-lg-3 col-md-4 col-sm-6 mb-4">

                    <div class="card payment-card shadow-sm">

                        <div class="card-strip"></div>

                        <div class="card-body text-center p-3">

                            <img src="@row["Personal_Photo"]"
                                 class="student-photo"
                                 onerror="this.onerror=null;this.src='https://cdn-icons-png.flaticon.com/512/149/149071.png';" />

                            <div class="student-name mt-2">
                                @row["StudentName"]
                            </div>

                            <div class="mt-3 text-start">

                                <div class="info-text">
                                    <b>Payment ID :</b>
                                    @row["PaymentId"]
                                </div>

                                <div class="info-text">
                                    <b>Payment Date :</b>
                                    @Convert.ToDateTime(row["PaymentDate"]).ToString("dd MMM yyyy")
                                </div>

                            </div>

                            <div class="amount-box">

                                <div style="font-size:13px;">
                                    Amount Paid
                                </div>

                                <div class="amount">
                                    ₹ @row["Amount"]
                                </div>

                            </div>

                            <div class="mt-3">

                                <span class="status-badge @(status == "Success" ? "paid" : "pending")">
                                    @status
                                </span>

                            </div>

                            <!-- DOWNLOAD BUTTON -->

                            <div class="mt-3">

                                <a href="@Url.Action("DownloadReceipt", "Trainer", new { id = row["Id"] })"
                                   class="download-btn">

                                    <i class="bi bi-download me-2"></i>

                                    Download Receipt

                                </a>

                            </div>

                        </div>

                    </div>

                </div>
            }
        }
        else
        {
            <div class="col-12">

                <div class="alert alert-warning text-center">

                    No Payment Records Found

                </div>

            </div>
        }

    </div>

</body>

</html>