@model JobVacancyModel

@{
    
    ViewData["Title"] = "Add Vacancy";
    Layout = "~/Views/Shared/Placement_Coordinator_layout.cshtml";


}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet">



    
<style>
    /* ===== PREMIUM CSS FOR ADD VACANCY PAGE ===== */
    /* Paste this CSS after bootstrap links or inside <style> */

    /* BODY */
    body {
        background: linear-gradient(135deg,#f8f6fc,#f5f7ff,#ffffff);
        font-family: 'Segoe UI',sans-serif;
    }

    /* TITLES */
    h4.fw-bold,
    .page-header h4 {
        font-weight: 700 !important;
        letter-spacing: .3px;
    }

    /* TOP BUTTON */
    .btn-primary {
        background: linear-gradient(135deg,#3b245f,#6d4db3) !important;
        border: none !important;
        border-radius: 12px !important;
        padding: 10px 18px !important;
        font-weight: 600;
        box-shadow: 0 10px 20px rgba(59,36,95,.18);
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 16px 28px rgba(59,36,95,.25);
        }

    /* PAGE HEADER */
    .page-header {
        background: linear-gradient(135deg,#3b245f,#6d4db3) !important;
        border-radius: 18px !important;
        padding: 18px 24px !important;
        box-shadow: 0 14px 30px rgba(59,36,95,.14) !important;
    }

    /* VACANCY CARD */
    .card {
        border: none !important;
        border-radius: 22px !important;
        overflow: hidden;
        box-shadow: 0 14px 32px rgba(59,36,95,.08) !important;
        transition: .35s ease;
    }

        .card:hover {
            transform: translateY(-8px);
            box-shadow: 0 22px 40px rgba(59,36,95,.15) !important;
        }

        /* CARD HEADER */
        .card div[style*="linear-gradient(135deg,#6a11cb,#8e54e9)"] {
            background: linear-gradient(135deg,#3b245f,#6d4db3,#8c6ad8) !important;
        }

    /* JOB TITLE */
    .card-body h5 {
        color: #3b245f !important;
        font-weight: 700;
    }

    /* CARD BODY */
    .card-body {
        padding: 22px !important;
    }

    /* BADGES */
    .badge.bg-danger {
        background: #ef4444 !important;
        border-radius: 20px;
        padding: 7px 12px !important;
    }

    .badge.bg-light {
        background: #ffffff !important;
        color: #3b245f !important;
        font-weight: 600;
        border-radius: 20px;
    }

    /* VIEW BUTTON */
    .viewBtn {
        background: #ede9fe !important;
        color: #3b245f !important;
        border: none !important;
        border-radius: 25px !important;
        font-weight: 600;
    }

    /* DELETE BUTTON */
    .btn-danger {
        border-radius: 25px !important;
        font-weight: 600;
    }

    /* MODALS */
    .modal-content {
        border: none !important;
        border-radius: 22px !important;
        overflow: hidden;
        box-shadow: 0 22px 45px rgba(0,0,0,.12);
    }

    .modal-header {
        background: linear-gradient(135deg,#3b245f,#6d4db3) !important;
        border: none !important;
    }

    .modal-title {
        font-weight: 700;
    }

    .btn-close {
        filter: brightness(0) invert(1);
    }

    /* MODAL BODY */
    .modal-body {
        background: #f8f6fc !important;
        padding: 24px !important;
    }

    /* INPUTS */
    .form-control,
    select,
    textarea {
        border-radius: 12px !important;
        min-height: 46px;
        border: 1px solid #e5e7eb !important;
        box-shadow: none !important;
    }

    textarea {
        min-height: 100px;
    }

        .form-control:focus,
        select:focus,
        textarea:focus {
            border-color: #3b245f !important;
            box-shadow: 0 0 0 .18rem rgba(59,36,95,.12) !important;
        }

    /* LABEL */
    label {
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
    }

    /* FOOTER BUTTONS */
    .modal-footer .btn {
        border-radius: 25px !important;
        padding: 8px 22px !important;
        font-weight: 600;
    }

    .modal-footer .btn-secondary {
        background: #e5e7eb;
        color: #111827;
        border: none;
    }

    /* ACTIVE CHECK BOX BOX */
    div[style*="border:1px solid #ddd"] {
        border: 1px solid #ede9fe !important;
        border-radius: 14px !important;
        background: #ffffff !important;
        padding: 14px !important;
    }

    /* SUCCESS MODAL ICON */
    .text-success {
        color: #16a34a !important;
    }

    /* SCROLLBAR */
    ::-webkit-scrollbar {
        width: 8px;
    }

    ::-webkit-scrollbar-thumb {
        background: #c4b5fd;
        border-radius: 10px;
    }
</style>


    @if (TempData["success"] != null)
