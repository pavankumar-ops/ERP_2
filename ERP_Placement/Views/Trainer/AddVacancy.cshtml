<!-- ADD VACANCY MODAL -->

<div class="modal fade" id="vacancyModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" style=" background:#f8f6fc; border-radius:12px;overflow:hidden;">

            <!-- HEADER -->

            <div class="modal-header text-white"
                 style="background:linear-gradient(135deg,#3b245f,#6d4db3);">

                <h5 class="modal-title fw-bold">
                    Add Job Vacancy
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>

            </div>

            <!-- BODY -->

            <div class="modal-body"
                 style="background:#f7f3ff;padding:25px;">

                <input type="hidden" id="CompanyId" value="@Model.CompanyId" />

                <div class="row">

                    <!-- Job Title -->

                    <div class="col-md-6 mb-3">
                        <label style="font-weight:600;">Job Title *</label>

                        <input type="text"
                               id="JobTitle"
                               class="form-control"
                               style="border-radius:8px;">
                    </div>

                    <!-- Openings -->

                    <div class="col-md-6 mb-3">
                        <label style="font-weight:600;">No Of Openings *</label>

                        <input type="number"
                               id="NoOfOpenings"
                               class="form-control"
                               style="border-radius:8px;">
                    </div>

                    <!-- Location -->

                    <div class="col-md-6 mb-3">
                        <label style="font-weight:600;">Job Location *</label>

                        <input type="text"
                               id="JobLocation"
                               class="form-control"
                               style="border-radius:8px;">
                    </div>

                    <!-- Salary -->

                    <div class="col-md-6 mb-3">
                        <label style="font-weight:600;">Salary</label>

                        <input type="number"
                               id="Salary"
                               class="form-control"
                               style="border-radius:8px;">
                    </div>

                    <!-- Job Type -->

                    <div class="col-md-6 mb-3">
                        <label style="font-weight:600;">Job Type *</label>

                        <select id="JobType"
                                class="form-control"
                                style="border-radius:8px;">

                            <option value="">Select</option>
                            <option>Full Time</option>
                            <option>Part Time</option>
                            <option>Internship</option>

                        </select>
                    </div>

                    <!-- Experience -->

                    <div class="col-md-6 mb-3">
                        <label style="font-weight:600;">Experience Required</label>

                        <input type="text"
                               id="ExperienceRequired"
                               class="form-control"
                               style="border-radius:8px;">
                    </div>

                    <!-- Qualification -->

                    <div class="col-md-6 mb-3">
                        <label style="font-weight:600;">Qualification *</label>

                        <input type="text"
                               id="Qualification"
                               class="form-control"
                               style="border-radius:8px;">
                    </div>

                    <!-- Last Date -->

                    <div class="col-md-6 mb-3">
                        <label style="font-weight:600;">Last Date *</label>

                        <input type="date"
                               id="LastDate"
                               class="form-control"
                               style="border-radius:8px;">
                    </div>

                    <!-- Job Description -->

                    <div class="col-md-12 mb-3">
                        <label style="font-weight:600;">Job Description</label>

                        <textarea id="JobDescription"
                                  rows="3"
                                  class="form-control"
                                  style="border-radius:8px;"></textarea>
                    </div>

                    <!-- Skills -->

                    <div class="col-md-12 mb-3">
                        <label style="font-weight:600;">Skills Required</label>

                        <input type="text"
                               id="SkillsRequired"
                               class="form-control"
                               placeholder="Example: C#, SQL, HTML"
                               style="border-radius:8px;">
                    </div>

                    <!-- Active Checkbox -->

                    <div class="col-md-12">

                        <div style="background:white;padding:10px;border-radius:8px;border:1px solid #ddd;">

                            <label style="font-weight:600;">
                                <input type="checkbox"
                                       id="IsActive"
                                       checked
                                       style="margin-right:6px;">

                                Vacancy Active

                            </label>

                        </div>

                    </div>

                </div>

            </div>

            <!-- FOOTER -->

            <div class="modal-footer"
                 style="background:#f7f3ff;">

                <button class="btn"
                        onclick="SaveVacancy()"
                        style=" background:#3b245f; color:white; border-radius:25px;padding:8px 25px;">

                    Save Vacancy

                </button>

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal"
                        style="border-radius:25px;">

                    Close

                </button>

            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>


<script>

    function SaveVacancy() {

        if ($("#JobTitle").val() == "") {
            toastr.error("Job Title Required");
            return;
        }

        if ($("#NoOfOpenings").val() == "") {
            toastr.error("Enter No Of Openings");
            return;
        }

        if ($("#JobLocation").val() == "") {
            toastr.error("Enter Job Location");
            return;
        }

        if ($("#JobType").val() == "") {
            toastr.error("Select Job Type");
            return;
        }

        if ($("#Qualification").val() == "") {
            toastr.error("Qualification Required");
            return;
        }

        if ($("#LastDate").val() == "") {
            toastr.error("Select Last Date");
            return;
        }

        var model = {

            CompanyId: $("#CompanyId").val(),
            JobTitle: $("#JobTitle").val(),
            JobDescription: $("#JobDescription").val(),
            NoOfOpenings: $("#NoOfOpenings").val(),
            JobLocation: $("#JobLocation").val(),
            Salary: $("#Salary").val(),
            JobType: $("#JobType").val(),
            ExperienceRequired: $("#ExperienceRequired").val(),
            Qualification: $("#Qualification").val(),
            SkillsRequired: $("#SkillsRequired").val(),
            LastDate: $("#LastDate").val(),
            IsActive: $("#IsActive").is(":checked")
        };

        $.ajax({

            url: '/Trainer/SaveVacancy',
            type: 'POST',
            data: model,

            success: function (res) {

                if (res.success) {

                    toastr.success(res.message);

                    setTimeout(function () {
                        location.reload();
                    }, 1200);

                } else {

                    toastr.error(res.message);

                }
            }

        });

    }

</script>


<script>

    $(document).on("click",".viewBtn",function(){

    var btn=$(this);

    $("#m_title").text(btn.data("title"));
    $("#m_desc").text(btn.data("desc"));
