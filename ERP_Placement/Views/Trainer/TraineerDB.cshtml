
@{
    ViewData["Title"] = "Student Enrollment";
    Layout = "~/Views/Shared/Placement_Coordinator_layout.cshtml";
}


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Placement Coordinator Dashboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>


    <style>

        .dashboard-card:hover {
            transform: translateY(-8px) scale(1.02);
        }

        /* Shine effect */
        .shine-effect {
            position: absolute;
            top: 0;
            left: -80%;
            width: 50%;
            height: 100%;
            background: linear-gradient( 120deg, rgba(255,255,255,0) 0%, rgba(255,255,255,.35) 50%, rgba(255,255,255,0) 100% );
            transform: skewX(-25deg);
            transition: all .8s ease;
        }

        .dashboard-card:hover .shine-effect {
            left: 130%;
        }

    </style>

</head>

<body id="body" style="
background:#f4f6fb;
font-family:'Inter','Segoe UI',sans-serif;
transition:0.3s;
">

    <div class="container-fluid p-3 p-lg-4">

        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center flex-wrap mb-4">
            <div>
                <h3 style="font-weight:700;">Placement Module – Coordinator Dashboard</h3>
                <p class="text-muted mb-0">Welcome to your Placement Management Overview</p>
            </div>
           
        </div>

        <!-- TOP STATS -->
        <div class="row g-4 mb-4">

            <!-- Students -->
            <div class="col d-flex" style="flex:0 0 20%;max-width:20%;">
                <div onclick="location.href='/Trainer/Stud_List'"
                     class="w-100 h-100 position-relative dashboard-card"
                     style="
             background:linear-gradient(135deg,#2563eb,#1d4ed8,#1e40af);
             color:white;
             padding:24px;
             border-radius:18px;
             cursor:pointer;
             overflow:hidden;
             box-shadow:0 14px 28px rgba(37,99,235,.28);
             transition:all .35s ease;">

                    <span class="shine-effect"></span>

                    <div style="position:absolute;top:-25px;right:-20px;width:95px;height:95px;background:rgba(255,255,255,.10);border-radius:50%;"></div>

                    <i class="bi bi-people-fill fs-1"></i>
                    <h2 class="fw-bold mt-3 mb-1">@ViewBag.StudentCount</h2>
                    <span style="font-size:15px;opacity:.95;">Students</span>
                </div>
            </div>

            <!-- Companies -->
            <div class="col d-flex" style="flex:0 0 20%;max-width:20%;">
                <div onclick="location.href='/Trainer/CompanyList'"
                     class="w-100 h-100 position-relative dashboard-card"
                     style="
             background:linear-gradient(135deg,#22c55e,#16a34a,#15803d);
             color:white;
             padding:24px;
             border-radius:18px;
             cursor:pointer;
             overflow:hidden;
             box-shadow:0 14px 28px rgba(34,197,94,.28);
             transition:all .35s ease;">

                    <span class="shine-effect"></span>

                    <div style="position:absolute;top:-25px;right:-20px;width:95px;height:95px;background:rgba(255,255,255,.10);border-radius:50%;"></div>

                    <i class="bi bi-building-fill fs-1"></i>
                    <h2 class="fw-bold mt-3 mb-1">@ViewBag.CompanyCount</h2>
                    <span style="font-size:15px;opacity:.95;">Total Company</span>
                </div>
            </div>

            <!-- Interview -->
            <div class="col d-flex" style="flex:0 0 20%;max-width:20%;">
                <div onclick="location.href='/Trainer/ScheduleInterview'"
                     class="w-100 h-100 position-relative dashboard-card"
                     style="
             background:linear-gradient(135deg,#8b5cf6,#7c3aed,#5b21b6);
             color:white;
             padding:24px;
             border-radius:18px;
             cursor:pointer;
             overflow:hidden;
             box-shadow:0 14px 28px rgba(139,92,246,.28);
             transition:all .35s ease;">

                    <span class="shine-effect"></span>

                    <div style="position:absolute;top:-25px;right:-20px;width:95px;height:95px;background:rgba(255,255,255,.10);border-radius:50%;"></div>

                    <i class="bi bi-person-video3 fs-1"></i>
                    <h2 class="fw-bold mt-3 mb-1">@ViewBag.InterviewCount</h2>
                    <span style="font-size:15px;opacity:.95;">Scheduled Interview</span>
                </div>
            </div>

            <!-- Offers -->
            <div class="col d-flex" style="flex:0 0 20%;max-width:20%;">
                <div onclick="location.href='/Trainer/MakeOfferLetter'"
                     class="w-100 h-100 position-relative dashboard-card"
                     style="
             background:linear-gradient(135deg,#ec4899,#db2777,#be185d);
             color:white;
             padding:24px;
             border-radius:18px;
             cursor:pointer;
             overflow:hidden;
             box-shadow:0 14px 28px rgba(236,72,153,.28);
             transition:all .35s ease;">

                    <span class="shine-effect"></span>

                    <div style="position:absolute;top:-25px;right:-20px;width:95px;height:95px;background:rgba(255,255,255,.10);border-radius:50%;"></div>

                    <i class="bi bi-award-fill fs-1"></i>
                    <h2 class="fw-bold mt-3 mb-1">@ViewBag.OfferCount</h2>
                    <span style="font-size:15px;opacity:.95;">Offers Made</span>
                </div>
            </div>

            <!-- Premium Users -->
            <div class="col d-flex" style="flex:0 0 20%;max-width:20%;">
                <div onclick="location.href='/Trainer/PremiumUsers'"
                     class="w-100 h-100 position-relative dashboard-card"
                     style="
             background:linear-gradient(135deg,#f59e0b,#d97706,#b45309);
             color:white;
             padding:24px;
             border-radius:18px;
             cursor:pointer;
             overflow:hidden;
             box-shadow:0 14px 28px rgba(245,158,11,.28);
             transition:all .35s ease;">

                    <span class="shine-effect"></span>

                    <div style="position:absolute;top:-25px;right:-20px;width:95px;height:95px;background:rgba(255,255,255,.10);border-radius:50%;"></div>

                    <i class="bi bi-gem fs-1"></i>
                    <h2 class="fw-bold mt-3 mb-1">@ViewBag.PremiumUserCount</h2>
                    <span style="font-size:15px;opacity:.95;">Premium Users</span>
                </div>
            </div>

        </div>


        <!-- MAIN CONTENT -->
        <div class="row g-4">

            <!-- STUDENT APPLICATIONS -->
            <div class="col-lg-4">
                <div class="bg-white p-3 rounded-4 shadow-sm">

                    <div class="d-flex justify-content-between mb-2">
                        <b>Recent Registered Students</b>
                        <a href="/Trainer/Stud_List">View All</a>
                    </div>

                    <div class="list-group list-group-flush">

                        @foreach (var student in ViewBag.RecentStudents)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">

                                <span>
                                    @student.FirstName  @student.LastName  <br>
                                    <small>@student.Branch</small>
                                </span>

                                <div style="min-width:120px;">
                                    @if (student.Status == "Approved")
                                    {
                                        <button class="btn btn-success btn-sm w-100" disabled>
                                            Approved
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-danger btn-sm w-100" disabled>
                                            Not Approved
                                        </button>
                                    }
                                </div>

                            </div>
                        }

                    </div>

                </div>
            </div>

            <!-- UPCOMING INTERVIEWS -->
            <div class="col-lg-4">
                <div class="bg-white p-3 rounded-4 shadow-sm">

                    <div class="d-flex justify-content-between mb-2">
                        <b>Upcoming Interviews</b>
                        <a href="/Trainer/ScheduleInterview">View All</a>
                    </div>

                    @foreach (var interview in ViewBag.UpcomingInterviews)
                    {
                        <div class="border rounded p-2 mb-2 d-flex justify-content-between align-items-center">

                            <div>
                                <b>@interview.Postion</b><br>
                                <small>@interview.CompanyName</small>
                            </div>

                            <small class="text-muted text-end">
                                @interview.InterviewDate.ToString("MMM dd")<br>
                                @DateTime.Parse(interview.InterviewTime).ToString("hh:mm tt")
                            </small>

                        </div>
                    }

                </div>
            </div>
            <!-- PLACEMENT ACTIVITY -->
            <div class="col-lg-4">
                <div style="background:white;
                padding:18px;
                border-radius:16px;
                box-shadow:0 6px 18px rgba(0,0,0,0.08);">

                    <div style="display:flex;
                    justify-content:space-between;
                    margin-bottom:14px;">

                        <b style="font-size:16px;">Placement Reminders</b>

                    </div>

                    <!-- Reminder 1 -->
                    <div style="border-left:4px solid #3b82f6;
                    padding-left:10px;
                    margin-bottom:14px;">

                        <b>Review Applications</b>
                        <p style="font-size:13px;color:#666;margin:2px 0 0 0;">
                            Check new student applications and shortlist candidates for interviews.
                        </p>

                    </div>

                    <!-- Reminder 2 -->
                    <div style="border-left:4px solid #22c55e;
                    padding-left:10px;
                    margin-bottom:14px;">

                        <b>Schedule Interviews</b>
                        <p style="font-size:13px;color:#666;margin:2px 0 0 0;">
                            Arrange interview slots for shortlisted students with companies.
                        </p>

                    </div>

                    <!-- Reminder 3 -->
                    <div style="border-left:4px solid #f59e0b;
                    padding-left:10px;">

                        <b>Follow Up Offers</b>
                        <p style="font-size:13px;color:#666;margin:2px 0 0 0;">
                            Track offer letters and confirm student joining status.
                        </p>

                    </div>

                </div>
            </div>

            <!-- LATEST JOBS -->
            <div class="col-lg-4">
                <div class="bg-white p-3 rounded-4 shadow-sm">

                    <div class="d-flex justify-content-between mb-2">
                        <b>Latest Job Openings</b>
                        <a href="/Trainer/CompanyList">View All</a>
                    </div>

                    @foreach (var job in ViewBag.LatestJobs)
                    {
                        <div class="border rounded p-2 mt-2 d-flex justify-content-between align-items-center">

                            <div>
                                <b>@job.CompanyName</b><br>
                                <small class="text-primary fw-semibold">@job.Position</small>
                            </div>

                            <span class="badge bg-success">₹@job.Salary</span>

                        </div>
                    }

                </div>
            </div>

            <!-- GRAPH -->
            <div class="col-lg-5">
                <div class="bg-white p-3 rounded-4 shadow-sm">
                    <b>Placement Activity</b>
                    <canvas id="placementChart" height="160"></canvas>
                </div>
            </div>

            <!-- TASKS -->
            <div class="col-lg-3">
                <div style="background:#ffffff;
                padding:18px;
                border-radius:16px;
                box-shadow:0 6px 18px rgba(0,0,0,0.08);
                height:100%;
                display:flex;
                flex-direction:column;">

                    <!-- Header -->
                    <div style="display:flex;
                    justify-content:space-between;
                    align-items:center;
                    margin-bottom:16px;">

                        <b style="font-size:16px;color:#222;">
                            Recent Added Tests
                        </b>

                        <a href="/Trainer/Test"
                           style="text-decoration:none;
                      background:linear-gradient(135deg,#4f46e5,#6366f1);
                      color:white;
                      padding:6px 12px;
                      border-radius:8px;
                      font-size:12px;
                      font-weight:600;">
                            + Add Test
                        </a>

                    </div>

                    <!-- Test List -->
                    <div style="flex-grow:1;">

                        @foreach (var test in ViewBag.RecentTests)
                        {
                            <div style="background:#f8fafc;
                                padding:12px;
                                border-radius:10px;
                                margin-bottom:12px;
                                transition:0.2s;">

                                <b style="font-size:14px;color:#111;">
                                    @test.TestName
                                </b><br>

                                <span style="font-size:12px;color:#6b7280;">
                                    @test.Branch
                                </span>

                            </div>
                        }

                    </div>

                    <!-- Bottom Button -->
                    <a href="/Trainer/TestList"
                       style="text-decoration:none;
                  text-align:center;
                  background:linear-gradient(135deg,#0ea5e9,#38bdf8);
                  color:white;
                  padding:10px;
                  border-radius:10px;
                  font-weight:600;
                  margin-top:10px;">
                        View All Tests
                    </a>

                </div>
            </div>

        </div>
    </div>

    <!-- GRAPH SCRIPT -->
    <script>
        const assignedCount = @ViewBag.AssignedCount;
        const appliedCount = @ViewBag.AppliedCount;
        const selectedCount = @ViewBag.SelectedCount;

        // find highest value
        const maxValue = Math.max(assignedCount, appliedCount, selectedCount);

        const ctx = document.getElementById('placementChart');

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Assigned Jobs', 'Applied Jobs', 'Selected Jobs'],
                datasets: [{
                    data: [assignedCount, appliedCount, selectedCount],
                    backgroundColor: ['#2563eb', '#fb923c', '#22c55e']
                }]
            },
            options: {
                responsive: true,
                animation: {
                    duration: 2000,
                    easing: 'easeOutQuart'
                },
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        max: maxValue + 2, // dynamic height based on highest count
                        ticks: {
                            stepSize: 1
                        }
                    }
                }
            }
        });
    </script>

    <!-- DARK MODE -->
    <script>
function toggleDark(){
let b=document.getElementById("body");
b.style.background="#0f172a";
document.querySelectorAll(".bg-white").forEach(e=>{
e.style.background="#1e293b";
e.style.color="#e5e7eb";
});
}
    </script>

</body>
</html>
