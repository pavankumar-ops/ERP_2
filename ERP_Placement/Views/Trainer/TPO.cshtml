@{
    ViewData["Title"] = "Training & Placement Cell";
    Layout = "~/Views/Shared/Placement_Coordinator_layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>

    /* Page Title */

    .page-title {
        text-align: center;
        font-size: 38px;
        font-weight: 700;
        margin-top: 35px;
        color: #3b245f;
    }

    /* Card */

    .member-card {
        border: none;
        border-radius: 12px;
        overflow: hidden;
        background: white;
        transition: 0.3s;
        box-shadow: 0 6px 18px rgba(0,0,0,0.12);
        height: 100%;
    }

        .member-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 28px rgba(59,36,95,0.35);
        }

    /* Image */

    .member-img {
        width: 100%;
        height: 230px;
        object-fit: cover;
    }

    /* Card body */

    .member-body {
        padding: 18px;
        text-align: center;
    }

    /* Name */

    .member-name {
        font-size: 18px;
        font-weight: 600;
        color: #3b245f;
    }

    /* Role */

    .member-role {
        font-size: 14px;
        color: #666;
    }

    /* Icons */

    .dept-icon {
        font-size: 20px;
        margin-top: 8px;
        color: #3b245f;
    }

    /* Badge */

    .badge {
        margin-top: 10px;
    }

    /* Responsive */

    .member-col {
        margin-bottom: 28px;
    }

</style>




