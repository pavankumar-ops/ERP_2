@model System.Data.DataTable

@{
    ViewBag.Title = "Registered Companies";
    Layout = "~/Views/Shared/Placement_Coordinator_layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<style>

    /* ===== PREMIUM ERP THEME ===== */

    body {
        background: linear-gradient(135deg,#f8f6fc,#f6f8ff,#ffffff);
        font-family: 'Segoe UI',sans-serif;
    }

    /* ===== PAGE TITLE ===== */

    .page-title {
        color: #3b245f;
        font-weight: 700;
        font-size: 28px;
        letter-spacing: .3px;
    }

    /* ===== FILTER BOX ===== */

    .filter-box {
        background: rgba(255,255,255,0.95);
        padding: 18px;
        border-radius: 18px;
        box-shadow: 0 10px 28px rgba(59,36,95,.08);
        border: 1px solid rgba(255,255,255,.7);
        margin-bottom: 28px;
        backdrop-filter: blur(8px);
    }

    /* ===== INPUTS ===== */

    .form-control,
    .form-select {
        border-radius: 12px;
        min-height: 46px;
        border: 1px solid #e5e7eb;
        transition: .3s;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: #3b245f;
            box-shadow: 0 0 0 .18rem rgba(59,36,95,.12);
        }

    /* ===== MAIN BUTTON ===== */

    .btn.text-white {
        background: linear-gradient(135deg,#3b245f,#6d4db3) !important;
        border: none;
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
        box-shadow: 0 8px 20px rgba(59,36,95,.20);
        transition: .3s;
    }

        .btn.text-white:hover {
            transform: translateY(-2px);
            box-shadow: 0 14px 28px rgba(59,36,95,.28);
        }

    /* ===== COMPANY CARD ===== */

    .company-card,
    .company-card-hover {
        border: none !important;
        border-radius: 22px !important;
        overflow: hidden;
        background: #ffffff;
        box-shadow: 0 14px 32px rgba(59,36,95,.08) !important;
        transition: all .35s ease;
    }

        .company-card:hover,
        .company-card-hover:hover {
            transform: translateY(-8px) scale(1.01);
            box-shadow: 0 24px 45px rgba(59,36,95,.14) !important;
        }

        /* ===== CARD HEADER ===== */

        .company-card-hover .text-white {
            background: linear-gradient(135deg,#3b245f,#6d4db3,#8c6ad8) !important;
        }

    /* ===== LOGO ===== */

    .company-logo,
    img[style*="width:55px"] {
        border-radius: 14px !important;
        background: #ffffff !important;
        padding: 6px !important;
        box-shadow: 0 6px 18px rgba(0,0,0,.08);
    }

    /* ===== COMPANY NAME ===== */

    .company-name {
        font-size: 18px;
        font-weight: 700;
        color: #1f2937;
    }

    /* ===== BADGE ===== */

    .badge-domain,
    .badge.bg-light {
        background: rgba(255,255,255,.18) !important;
        color: #ffffff !important;
        border-radius: 30px;
        padding: 6px 12px;
        font-weight: 600;
        font-size: 12px;
        border: 1px solid rgba(255,255,255,.25);
    }

    /* ===== DESCRIPTION ===== */

    .description-text {
        background: #f8f6fc;
        padding: 12px;
        border-radius: 14px;
        min-height: 75px !important;
        line-height: 1.5;
    }

    /* ===== READ MORE ===== */

    .read-more {
        color: #3b245f !important;
        font-weight: 600;
    }

    /* ===== CONTACT BOX ===== */

    .hr-box,
    div[style*="background:#f6f4ff"] {
        background: #f8f6fc !important;
        border-radius: 14px !important;
        padding: 14px !important;
        border: 1px solid #ede9fe;
    }

    /* ===== FOOTER ===== */

    .card-footer {
        padding-bottom: 18px !important;
    }

    /* ===== VACANCY BUTTON ===== */

    .btn-success {
        background: #dcfce7 !important;
        color: #166534 !important;
        border: none !important;
        border-radius: 10px;
        font-weight: 600;
        padding: 7px 14px;
    }

    /* ===== VIEW BUTTON ===== */

    .btn-primary {
        background: #ede9fe !important;
        color: #3b245f !important;
        border: none !important;
        border-radius: 10px;
        font-weight: 600;
        padding: 7px 14px;
    }

    /* ===== MODAL ===== */

    .modal-content {
        border: none;
        border-radius: 22px;
        overflow: hidden;
        box-shadow: 0 20px 45px rgba(0,0,0,.12);
    }

    .modal-header {
        background: linear-gradient(135deg,#3b245f,#6d4db3) !important;
        border: none;
    }

    .modal-title {
        font-weight: 700;
    }

    .btn-close {
        filter: brightness(0) invert(1);
    }

    /* ===== MODAL BODY ===== */

    .modal-body {
        padding: 24px;
    }

    /* ===== LABELS ===== */

    label {
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
    }

    /* ===== ALERT ===== */

    .alert-warning {
        border: none;
        border-radius: 16px;
        background: #fff8db;
        color: #7c5a00;
        padding: 18px;
    }

    /* ===== SCROLLBAR ===== */

    ::-webkit-scrollbar {
        width: 8px;
    }

    ::-webkit-scrollbar-thumb {
        background: #c4b5fd;
        border-radius: 10px;
    }

    ::-webkit-scrollbar-track {
        background: #f3f4f6;
    }

</style>


