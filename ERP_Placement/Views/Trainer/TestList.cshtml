@model List<Placement_Coordinator_Model>

@{
    ViewBag.Title = "Test List";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

<div class="container-fluid p-4">

    <!-- 🔷 Dashboard Header -->
    <div class="dashboard-header mb-4 p-4 rounded-4 text-white">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h2 class="fw-bold">
                    <i class="bi bi-journal-text"></i> Test Management
                </h2>
                <p class="mb-0">Manage and monitor all created tests easily</p>
            </div>
            <div class="col-md-4 text-end">
                <a href="@Url.Action("Test", "Trainer")"
                   class="btn btn-light px-4 fw-bold shadow-sm">
                    <i class="bi bi-plus-circle"></i> Add New Test
                </a>
            </div>
        </div>
    </div>

    <!-- 🔷 Summary + Search -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow border-0 rounded-4 text-center p-3">
                <h3 class="fw-bold text-primary">@Model.Count</h3>
                <span class="text-muted">Total Tests</span>
            </div>
        </div>

        <div class="col-md-8">
            <input type="text" id="searchBox"
                   class="form-control shadow-sm rounded-4"
                   placeholder="🔍 Search Test by Name or Branch...">
        </div>
    </div>

    <!-- 🔷 Test Cards -->
    <div class="row" id="testContainer">

        @if (Model.Count == 0)
        {
            <div class="col-12">
                <div class="alert alert-info text-center">
                    No Tests Available
                </div>
            </div>
        }
        else
        {
            foreach (var item in Model)
            {
                <div class="col-md-4 mb-4 test-item">
                    <div class="card test-card shadow-sm border-0 rounded-4 h-100">

                        <div class="card-body">

                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="fw-bold text-dark mb-0">
                                    @item.TestName
                                </h5>
                                <span class="badge bg-primary">
                                    @item.Branch
                                </span>
                            </div>

                            <p class="mt-3 mb-1">
                                <i class="bi bi-person"></i>
                                <strong>Created By:</strong> @item.CreatedBy
                            </p>

                            <p class="text-muted small">
                                <i class="bi bi-calendar"></i>
                                @item.CreatedDate.ToString("dd MMM yyyy")
                            </p>

                            <hr />

                            <div class="d-flex justify-content-between">

                                <a href="@Url.Action("ViewTest", "Trainer", new { id = item.TestId })"
                                   class="btn btn-outline-success btn-sm px-3 rounded-pill">
                                    <i class="bi bi-eye"></i> View
                                </a>

                                <a href="@Url.Action("EditTest", "Trainer", new { id = item.TestId })"
                                   class="btn btn-outline-warning btn-sm px-3 rounded-pill">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>

                            </div>

                        </div>
                    </div>
                </div>
            }
        }

    </div>

</div>

<!-- 🔷 Styling -->
<style>
    .dashboard-header {
        background: linear-gradient(135deg, #2563eb, #1e40af);
    }

    .test-card {
        transition: all 0.3s ease;
        cursor: pointer;
    }

        .test-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15);
        }
</style>

<!-- 🔷 Search Script -->
<script>
    document.getElementById("searchBox").addEventListener("keyup", function () {
        let value = this.value.toLowerCase();
        let cards = document.querySelectorAll(".test-item");

        cards.forEach(function (card) {
            card.style.display =
                card.innerText.toLowerCase().includes(value)
                    ? "block"
                    : "none";
        });
    });
</script>