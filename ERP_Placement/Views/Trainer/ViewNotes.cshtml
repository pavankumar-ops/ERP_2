@model ERP_Placement.Models.TopicNotes

@{
    ViewData["Title"] = "View Notes";
}

<div class="container mt-5">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-body p-4">

            <h2 class="fw-bold text-primary mb-2">
                @Model.TopicName
            </h2>

            <h5 class="text-secondary mb-3">
                @Model.SubjectName
            </h5>

            <hr />

            <p class="mb-4">
                @Model.Description
            </p>

            @if (!string.IsNullOrEmpty(Model.PdfPath))
            {
                <iframe src="@Url.Content(Model.PdfPath)"
                        width="100%"
                        height="600"
                        style="border:1px solid #ddd; border-radius:10px;">
                </iframe>

                <div class="mt-3">
                    <a href="@Url.Content(Model.PdfPath)"
                       target="_blank"
                       class="btn btn-primary">
                        Download Notes
                    </a>
                </div>
            }
            else
            {
                <div class="alert alert-warning">
                    PDF Not Available
                </div>
            }

        </div>

    </div>

</div>