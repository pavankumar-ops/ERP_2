@model Placement_Coordinator_Model

@{
    ViewData["Title"] = "Register Company";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">
    <div class="card shadow">
        <div class="card-header bg-primary text-white fw-bold">
            Company Registration
        </div>

        <div class="card-body">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Success"]
                </div>
            }

            <form asp-action="CompanySave" method="post" class="row g-3">

                <input asp-for="CompanyName" class="form-control" placeholder="Company Name" required />

                <input name="CompanyLogo" type="file" class="form-control" placeholder="Company Logo Path" />

                <input asp-for="CompanyWebsite" class="form-control" placeholder="Company Website" />

                <textarea asp-for="CompanyDescription"
                          class="form-control"
                          rows="4"
                          placeholder="Company Description"></textarea>

                <button type="submit" class="btn btn-success w-100">
                    Register Company
                </button>

            </form>

        </div>
    </div>
</div>

