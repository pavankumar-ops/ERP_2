@model Placement_Coordinator_Model

@{
    ViewData["Title"] = "Register Company";
    Layout = "~/Views/Shared/Placement_Coordinator_layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">
    <div class="card shadow">
        <div class="card-header bg-primary text-white fw-bold">
            Company Registration
        </div>

        <div class="card-body">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Success"]
                </div>
            }

            <form asp-action="CompanySave"
                  method="post"
                  enctype="multipart/form-data"
                  class="row g-3">

                <input asp-for="CompanyName"
                       class="form-control"
                       placeholder="Company Name"
                       required />

                <input type="file"
                       name="CompanyLogo"
                       class="form-control"
                       accept="image/*" />

                <input asp-for="CompanyWebsite"
                       class="form-control"
                       placeholder="Company Website" />

                <input asp-for="CompanyDomain"
                       class="form-control"
                       placeholder="Company Domain" />
                <input asp-for="HRName"
                       class="form-control"
                       placeholder="HR Name" />
                <input asp-for="HRMail"
                       class="form-control"
                       placeholder="HR Mail" />
                <input asp-for="HRMobNo"
                       class="form-control"
                       placeholder="HR Mobile Number" />
               

                <textarea asp-for="CompanyDescription"
                          class="form-control"
                          rows="4"
                          placeholder="Company Description"></textarea>

                <button type="submit" class="btn btn-success w-100">
                    Register Company
                </button>
            </form>


        </div>
    </div>
</div>

