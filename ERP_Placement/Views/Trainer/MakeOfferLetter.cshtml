@model System.Data.DataTable

@{
    ViewBag.Title = "Interview Students";
    Layout = "~/Views/Shared/Placement_Coordinator_layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<style>

    .interview-card {
        border: none;
        border-radius: 15px;
        transition: 0.3s;
    }

        .interview-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.15);
        }

    .card-strip {
        height: 40px;
        background: linear-gradient(135deg,#6a11cb,#8e54e9);
    }

    .student-img {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        border: 4px solid white;
        margin-top: -40px;
        object-fit: cover;
    }

    .student-name {
        font-weight: 700;
        color: #6a11cb;
    }

</style>




<div class="d-flex align-items-center mb-4">

    <div style="width:45px;height:45px;background:linear-gradient(135deg,#6a11cb,#8e54e9);border-radius:10px;display:flex;align-items:center;justify-content:center;color:white;font-size:20px;margin-right:12px;">
        <i class="bi bi-people-fill"></i>
    </div>

    <div>
        <h3 style="margin:0;font-weight:700;color:#3b245f;letter-spacing:0.5px;">
            Make Offer Letters
        </h3>

        <div style="width:60px;height:3px;background:#6a11cb;margin-top:5px;border-radius:5px;"></div>

        <span style="font-size:13px;color:#6c757d;">
            Manage and track student interview applications
        </span>
    </div>

</div>

<div class="card shadow-sm mb-4 p-3">

    <div class="row">

        <div class="col-md-3">
            <label>Search Name</label>
            <input type="text" id="searchName" class="form-control" placeholder="Student Name">
        </div>

        <div class="col-md-3">
            <label> Status</label>
            <select id="filterStatus" class="form-control">
                <option value="">All</option>
                <option value="Applied">Applied</option>
                <option value="Selected">Selected</option>
               
            </select>
        </div>
       
        
    </div>

</div>
<div class="row">

    @if (Model != null)
    {
        foreach (System.Data.DataRow row in Model.Rows)
        {

            <div class="col-lg-3 col-md-4 col-sm-6 mb-4 studentCard"
                 data-name="@row["FirstName"] @row["LastName"]"
                 data-branch="@row["Branch"]"
                 data-company="@row["CompanyName"]"
                 data-status="@row["Status"]">

                <div class="card interview-card shadow">

                    <div class="card-strip"></div>

                    <div class="card-body text-center">

                        <img src="@row["Personal_Photo"]"
                             class="student-img"
                             onerror="this.onerror=null;this.src='https://cdn-icons-png.flaticon.com/512/149/149071.png';" />

                        <h6 class="student-name mt-2">
                            @row["FirstName"] @row["LastName"]
                        </h6>

                        <p class="small text-muted mb-1">
                            @row["CompanyName"]
                        </p>

                        <p class="small">
                            <b>@row["JobTitle"]</b>
                        </p>

                        <span class="badge bg-primary">
                            @row["Branch"]
                        </span>

                        <p class="small mt-2">
                            <b>Date :</b>
                            @Convert.ToDateTime(row["InterviewDate"]).ToString("dd-MM-yyyy")
                        </p>

                        <p class="small">
                            <b>Salary :</b> ₹@row["Salary"]
                        </p>

                        <div class="d-flex justify-content-center flex-wrap gap-1 mt-2">

                            <button class="btn btn-info btn-sm viewBtn"
                                    data-photo="@row["Personal_Photo"]"
                                    data-name="@row["FirstName"] @row["LastName"]"
                                    data-company="@row["CompanyName"]"
                                    data-job="@row["JobTitle"]"
                                    data-description="@row["JobDescription"]"
                                    data-location="@row["JobLocation"]"
                                    data-salary="@row["Salary"]"
                                    data-jobtype="@row["JobType"]"
                                    data-email="@row["Email"]"
                                    data-interviewtype="@row["InterviewType"]"
                                    data-date="@Convert.ToDateTime(row["InterviewDate"]).ToString("dd-MM-yyyy")"
                                    data-time="@row["InterviewTime"]"
                                    data-lastdate="@row["LastDateToApply"]"
                                    data-status="@row["Status"]">

                                View
                            </button>


                            @if (row["Status"].ToString() == "Applied")
                            {

                                <button class="btn btn-success btn-sm sendOfferBtn"
                                        data-interview="@row["InterviewId"]"
                                        data-student="@row["StudentId"]"
                                        data-company="@row["CompanyId"]"
                                        data-vacancy="@row["VacancyId"]"
                                        data-bs-toggle="modal"
                                        data-bs-target="#offerModal">

                                    Offer
                                </button>

                                <a href="@Url.Action("RejectStudentoffer", "Trainer", new { InterviewId = row["InterviewId"] })"
                                   class="btn btn-danger btn-sm">
                                    Reject
                                </a>

                            }
                            else if (row["Status"].ToString() == "Selected")
                            {

                                <button class="btn btn-warning btn-sm viewOfferBtn"
                                        data-interview="@row["InterviewId"]"
                                        data-bs-toggle="modal"
                                        data-bs-target="#viewOfferModal">

                                    View Offer
                                </button>

                                <a href="@Url.Action("DownloadOfferLetter", "Trainer", new { interviewId = row["InterviewId"] })"
                                   class="btn btn-primary btn-sm">

                                    Download
                                </a>

                            }

                        </div>

                    </div>

                </div>

            </div>

        }
    }

</div>





<!-- VIEW DETAILS MODAL -->

<div class="modal fade" id="viewDetailsModal">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header text-white"
                 style="background:linear-gradient(135deg,#6a11cb,#8e54e9);">

                <h5 class="modal-title">Interview Details</h5>

                <button class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>

            </div>

            <div class="modal-body">

                <div class="row">

                    <div class="col-md-4 text-center">

                        <img id="m_photo"
                             style="width:120px;height:120px;border-radius:50%;border:5px solid #6a11cb;" />

                        <h5 id="m_name" class="mt-2"></h5>

                        <p id="m_email"></p>

                    </div>

                    <div class="col-md-8">

                        <p><b>Company :</b> <span id="m_company"></span></p>

                        <p><b>Job Title :</b> <span id="m_job"></span></p>

                        <p><b>Description :</b> <span id="m_description"></span></p>

                        <p><b>Location :</b> <span id="m_location"></span></p>

                        <p><b>Salary :</b> <span id="m_salary"></span></p>

                        <p><b>Job Type :</b> <span id="m_jobtype"></span></p>

                        <hr>

                        <p><b>Interview Type :</b> <span id="m_interviewtype"></span></p>

                        <p><b>Date :</b> <span id="m_date"></span></p>

                        <p><b>Time :</b> <span id="m_time"></span></p>

                        <p><b>Last Date :</b> <span id="m_lastdate"></span></p>

                        <p><b>Status :</b> <span id="m_status"></span></p>

                    </div>

                </div>

            </div>

        </div>
    </div>
</div>



<!-- VIEW OFFER LETTER -->

<div class="modal fade" id="viewOfferModal">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Offer Letter</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <iframe id="offerIframe" style="width:100%;height:600px;"></iframe>
            </div>

        </div>
    </div>
</div>



<!-- UPLOAD OFFER LETTER -->

<div class="modal fade" id="offerModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5>Upload Offer Letter</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form method="post" action="/Trainer/UploadOfferLetter" enctype="multipart/form-data">

                <div class="modal-body">

                    <input type="hidden" name="InterviewId" id="InterviewId" />
                    <input type="hidden" name="StudentId" id="StudentId" />
                    <input type="hidden" name="CompanyId" id="CompanyId" />
                    <input type="hidden" name="VacancyId" id="VacancyId" />

                    <div class="mb-3">
                        <label>Upload Offer Letter</label>
                        <input type="file" name="OfferLetterFile" class="form-control" required />
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Save Offer Letter</button>
                </div>

            </form>

        </div>
    </div>
</div>



<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>


<script>

    $(".viewBtn").click(function(){

    var btn=$(this);

    $("#m_photo").attr("src",btn.data("photo"));
    $("#m_name").text(btn.data("name"));
    $("#m_email").text(btn.data("email"));

    $("#m_company").text(btn.data("company"));
    $("#m_job").text(btn.data("job"));
    $("#m_description").text(btn.data("description"));
    $("#m_location").text(btn.data("location"));
    $("#m_salary").text(btn.data("salary"));
    $("#m_jobtype").text(btn.data("jobtype"));

    $("#m_interviewtype").text(btn.data("interviewtype"));
    $("#m_date").text(btn.data("date"));
    $("#m_time").text(btn.data("time"));
    $("#m_lastdate").text(btn.data("lastdate"));
    $("#m_status").text(btn.data("status"));

    $("#viewDetailsModal").modal("show");

    });



    $(".sendOfferBtn").click(function(){

    var interviewId = $(this).data("interview");
    var studentId = $(this).data("student");
    var companyId = $(this).data("company");
    var vacancyId = $(this).data("vacancy");

    $("#InterviewId").val(interviewId);
    $("#StudentId").val(studentId);
    $("#CompanyId").val(companyId);
    $("#VacancyId").val(vacancyId);

    });


    $(".viewOfferBtn").click(function(){

    var interviewId = $(this).data("interview");
    var url = "/Trainer/ViewOfferLetter?interviewId=" + interviewId;

    $("#offerIframe").attr("src",url);

    });


    $('#viewOfferModal').on('hidden.bs.modal', function () {
    $("#offerIframe").attr("src","");
    });

</script>

<script>

    function filterCards(){

    var name = $("#searchName").val().toLowerCase();
    var status = $("#filterStatus").val();
    var branch = $("#filterBranch").val();
    var company = $("#filterCompany").val();

    $(".studentCard").each(function(){

    var card = $(this);

    var studentName = card.data("name").toLowerCase();
    var studentBranch = card.data("branch");
    var studentCompany = card.data("company");
    var studentStatus = card.data("status");

    var show = true;

    if(name && !studentName.includes(name))
    show = false;

    if(status && studentStatus != status)
    show = false;

    if(branch && studentBranch != branch)
    show = false;

    if(company && studentCompany != company)
    show = false;

    if(show)
    card.show();
    else
    card.hide();

    });

    }

    $("#searchName").on("keyup",filterCards);
    $("#filterStatus").on("change",filterCards);
    $("#filterBranch").on("keyup",filterCards);
    $("#filterCompany").on("keyup",filterCards);

</script>

<script>

    $(document).ready(function () {

        var message = '@(TempData["Message"] ?? "")';

        if (message.trim() !== "") {

            var modal = new bootstrap.Modal(document.getElementById('messageModal'));
            modal.show();

        }

    });

</script>