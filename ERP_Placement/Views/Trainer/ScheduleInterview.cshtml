@{
    ViewData["Title"] = "Schedule Interview";
    Layout = "~/Views/Shared/Placement_Coordinator_layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet">


<style>
    .select2-container .select2-selection--single {
        height: 38px;
        padding-top: 5px;
    }
    
    .interview-card {
        border: none;
        border-radius: 15px;
        transition: 0.3s;
    }

        .interview-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 28px rgba(0,0,0,0.15);
        }

    .card-strip {
        height: 40px;
        background: linear-gradient(135deg,#6a11cb,#8e54e9);
    }

    .student-img {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        border: 4px solid white;
        margin-top: -40px;
        object-fit: cover;
    }

    .student-name {
        font-weight: 700;
        color: #6a11cb;
    }


</style>



<div class="d-flex justify-content-between align-items-center p-3 mb-4 shadow-sm rounded"
     style="background:linear-gradient(135deg,#6a11cb,#8e54e9);color:white;">

    <div class="d-flex align-items-center">

        <img src="https://cdn-icons-png.flaticon.com/512/3135/3135755.png"
             style="width:40px;height:40px;margin-right:10px;">

        <h4 class="mb-0 fw-bold">
            Scheduled Interviews
        </h4>

    </div>

    <button class="btn btn-light fw-bold px-3"
            data-bs-toggle="modal"
            data-bs-target="#InterviewModal">

        + Schedule Interview

    </button>

</div>


    <div class="row">

        @if (ViewBag.InterviewList != null)
        {
            foreach (System.Data.DataRow row in ViewBag.InterviewList.Rows)
            {

                <div class="col-lg-3 col-md-4 col-sm-6 mb-4">

                    <div class="card shadow interview-card">

                        <div class="card-strip"></div>

                        <div class="card-body text-center">

                            <img src="@row["Personal_Photo"]"
                                 class="student-img"
                                 onerror="this.onerror=null;this.src='https://cdn-icons-png.flaticon.com/512/149/149071.png';" />

                            <h6 class="student-name mt-2">
                                @row["FirstName"] @row["LastName"]
                            </h6>

                            <p class="small text-muted">
                                @row["JobTitle"]
                            </p>

                            <span class="badge bg-primary">
                                @row["InterviewType"]
                            </span>

                            <p class="small mt-2">
                                <b>Date :</b>
                                @Convert.ToDateTime(row["InterviewDate"]).ToString("dd-MM-yyyy")
                            </p>

                            <button class="btn btn-primary btn-sm viewInterview"
                                    data-student="@row["FirstName"] @row["LastName"]"
                                    data-photo="@row["Personal_Photo"]"
                                    data-company="@row["CompanyName"]"
                                    data-job="@row["JobTitle"]"
                                    data-description="@row["JobDescription"]"
                                    data-location="@row["JobLocation"]"
                                    data-salary="@row["Salary"]"
                                    data-jobtype="@row["JobType"]"
                                    data-interviewtype="@row["InterviewType"]"
                                    data-date="@Convert.ToDateTime(row["InterviewDate"]).ToString("dd-MM-yyyy")"
                                    data-time="@row["InterviewTime"]"
                                    data-lastdate="@row["LastDateToApply"]"
                                    data-status="@row["Status"]">

                                View

                            </button>

                        </div>

                    </div>

                </div>

            }
        }

    </div>



<div class="modal fade" id="interviewModal">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">

            <div class="modal-header text-white"
                 style="background:linear-gradient(135deg,#6a11cb,#8e54e9);">

                <h5 class="modal-title fw-bold">Interview Details</h5>

                <button class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>

            </div>

            <div class="modal-body" style="background:#f7f3ff;">

                <div class="row">

                    <!-- STUDENT PROFILE -->

                    <div class="col-md-4">

                        <div class="card border-0 shadow-sm text-center p-3">

                            <img id="m_photo"
                                 style="width:110px;height:110px;border-radius:50%;border:5px solid #6a11cb;object-fit:cover;margin:auto;" />

                            <h5 id="m_student" class="mt-3 fw-bold" style="color:#6a11cb;"></h5>

                            <span id="m_status" class="badge bg-success px-3 py-2 mt-2"></span>

                        </div>

                    </div>


                    <!-- DETAILS SECTION -->

                    <div class="col-md-8">

                        <!-- COMPANY / JOB INFO -->

                        <div class="card shadow-sm border-0 mb-3">

                            <div class="card-header fw-bold"
                                 style="background:#ede7ff;color:#6a11cb;">

                                Job Information

                            </div>

                            <div class="card-body">

                                <div class="row">

                                    <div class="col-md-6 mb-2">
                                        <b>Company :</b><br>
                                        <span id="m_company"></span>
                                    </div>

                                    <div class="col-md-6 mb-2">
                                        <b>Job Title :</b><br>
                                        <span id="m_job"></span>
                                    </div>

                                    <div class="col-md-6 mb-2">
                                        <b>Location :</b><br>
                                        <span id="m_location"></span>
                                    </div>

                                    <div class="col-md-6 mb-2">
                                        <b>Salary :</b><br>
                                        <span id="m_salary"></span>
                                    </div>

                                    <div class="col-md-6 mb-2">
                                        <b>Job Type :</b><br>
                                        <span id="m_jobtype"></span>
                                    </div>

                                    <div class="col-md-12 mt-2">
                                        <b>Description :</b><br>
                                        <span id="m_description"></span>
                                    </div>

                                </div>

                            </div>

                        </div>


                        <!-- INTERVIEW DETAILS -->

                        <div class="card shadow-sm border-0">

                            <div class="card-header fw-bold"
                                 style="background:#ede7ff;color:#6a11cb;">

                                Interview Information

                            </div>

                            <div class="card-body">

                                <div class="row">

                                    <div class="col-md-6 mb-2">
                                        <b>Interview Type :</b><br>
                                        <span id="m_interviewtype"></span>
                                    </div>

                                    <div class="col-md-6 mb-2">
                                        <b>Date :</b><br>
                                        <span id="m_date"></span>
                                    </div>

                                    <div class="col-md-6 mb-2">
                                        <b>Time :</b><br>
                                        <span id="m_time"></span>
                                    </div>

                                    <div class="col-md-6 mb-2">
                                        <b>Last Date To Apply :</b><br>
                                        <span id="m_lastdate"></span>
                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>
    </div>
</div>

<!-- MODAL -->

<div class="modal fade" id="InterviewModal">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">

            <!-- HEADER -->

            <div class="modal-header text-white"
                 style="background:linear-gradient(135deg,#6a11cb,#8e54e9);">

                <h5 class="modal-title fw-bold">
                    📅 Schedule Interview
                </h5>

                <button class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>

            </div>

            <!-- BODY -->

            <div class="modal-body" style="background:#f7f3ff;">

                <div class="row g-3">

                    <!-- COMPANY -->

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Company</label>

                        <select id="CompanyId" class="form-select">

                            <option value="">Select Company</option>

                            @foreach (System.Data.DataRow row in ViewBag.Compantlist.Rows)
                            {
                                <option value="@row["CompanyId"]">
                                    @row["CompanyName"]
                                </option>
                            }

                        </select>
                    </div>

                    <!-- VACANCY -->

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Job Vacancy</label>

                        <select id="VacancyId" class="form-select">
                            <option value="">Select Vacancy</option>
                        </select>

                    </div>

                    <!-- STUDENT -->

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Student</label>

                        <select id="StudentId" class="form-select">

                            <option value="">Select Student</option>

                            @foreach (System.Data.DataRow row in ViewBag.StudentList.Rows)
                            {
                                <option value="@row["StudentId"]">
                                    @row["FirstName"] @row["LastName"] (@row["Branch"])
                                </option>
                            }

                        </select>

                    </div>

                    <!-- BRANCH DROPDOWN -->

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Branch</label>

                        <select id="Branch" class="form-select">

                            <option value="">Select Branch</option>

                            <option>Computer Engineering</option>
                            <option>Information Technology</option>
                            <option>Electronics Engineering</option>
                            <option>Mechanical Engineering</option>
                            <option>Civil Engineering</option>

                        </select>

                    </div>

                    <!-- INTERVIEW TYPE -->

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Interview Type</label>

                        <select id="InterviewType" class="form-select">

                            <option value="">Select Type</option>

                            <option>Online</option>
                            <option>Offline</option>

                        </select>

                    </div>

                    <!-- DATE -->

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Interview Date</label>

                        <input type="date"
                               id="InterviewDate"
                               class="form-control">
                    </div>

                    <!-- TIME -->

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Interview Time</label>

                        <input type="time"
                               id="InterviewTime"
                               class="form-control">
                    </div>

                    <!-- LAST DATE -->

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Last Date To Apply</label>

                        <input type="date"
                               id="LastDateToApply"
                               class="form-control">
                    </div>

                </div>

            </div>

            <!-- FOOTER -->

            <div class="modal-footer">

                <button class="btn btn-success px-4"
                        onclick="SaveInterview()">

                    ✔ Save Interview

                </button>

                <button class="btn btn-outline-secondary"
                        data-bs-dismiss="modal">

                    Close

                </button>

            </div>

        </div>
    </div>
</div>


<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<script>

    function SaveInterview(){

     var company = $("#CompanyId").val();
    var vacancy = $("#VacancyId").val();
    var student = $("#StudentId").val();
    var branch = $("#Branch").val();
    var type = $("#InterviewType").val();
    var interviewDate = $("#InterviewDate").val();
    var interviewTime = $("#InterviewTime").val();
    var lastDate = $("#LastDateToApply").val();

    var today = new Date();

    // Required Fields Validation
    if (company == "") {
        toastr.warning("Please select Company Name");
        return;
    }

    if (vacancy == "") {
        toastr.warning("Please select Job Vacancy");
        return;
    }

    if (student == "") {
        toastr.warning("Please select Student");
        return;
    }

    if (branch == "") {
        toastr.warning("Please enter Branch");
        return;
    }

    if (type == "") {
        toastr.warning("Please select Interview Type");
        return;
    }

    if (lastDate == "") {
        toastr.warning("Please select Last Date To Apply");
        return;
    }

    if (interviewDate == "") {
        toastr.warning("Please select Interview Date");
        return;
    }

    if (interviewTime == "") {
        toastr.warning("Please select Interview Time");
        return;
    }

    // Last Date should be after 8 days from today
    var lastApplyDate = new Date(lastDate);
    var minLastDate = new Date();
    minLastDate.setDate(today.getDate() + 8);

    if (lastApplyDate < minLastDate) {
        toastr.error("Last Date To Apply must be at least 8 days from today");
        return;
    }

    // Interview date must be after 8 days of last date
    var interview = new Date(interviewDate);
    var minInterviewDate = new Date(lastApplyDate);
    minInterviewDate.setDate(lastApplyDate.getDate() + 8);

    if (interview < minInterviewDate) {
        toastr.error("Interview Date must be after 8 days from Last Date To Apply");
        return;
    }

    // Interview time between 9 AM and 6 PM
    var timeParts = interviewTime.split(":");
    var hour = parseInt(timeParts[0]);

    if (hour < 9 || hour >= 18) {
        toastr.error("Interview Time must be between 9 AM and 6 PM");
        return;
    }

    // If interview date selected before last date
    if (interviewDate && !lastDate) {
        toastr.warning("Please select Last Date To Apply first");
        return;
    }

    toastr.success("Validation Passed. Saving interview...");




    var model={

    VacancyId:$("#VacancyId").val(),
    StudentId:$("#StudentId").val(),
    Branch:$("#Branch").val(),
    InterviewType:$("#InterviewType").val(),
    InterviewDate:$("#InterviewDate").val(),
    InterviewTime:$("#InterviewTime").val(),
    LastDateToApply:$("#LastDateToApply").val()

    };

    $.ajax({

    url:'/Trainer/SaveInterview',
    type:'POST',
    data:model,

    success:function(res){

    if(res.success){

    toastr.success(res.message);

    setTimeout(function(){
    location.reload();
    },1200);

    }else{

    toastr.error(res.message);

    }

    }

    });

    }

</script>

<script>

    $(document).ready(function () {

    $("#StudentId").select2({

    placeholder: "Search Student",
    allowClear: true,
    width: '100',
    minimumResultsForSearch: 0

    });

    });

</script>



<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

    $("#CompanyId").change(function () {

        var companyId = $(this).val();

        if (companyId != "") {

            $.ajax({
                url: '/Trainer/GetVacancyByCompany',
                type: 'GET',
                data: { companyId: companyId },

                success: function (data) {

                    console.log(data); // debug

                    $("#VacancyId").empty();
                    $("#VacancyId").append('<option value="">Select</option>');

                    $.each(data, function (i, item) {

                        $("#VacancyId").append(
                            '<option value="' + item.vacancyId + '">' + item.jobTitle + '</option>'
                        );

                    });

                }

            });

        }

    });



        $(document).on("click",".viewInterview",function(){

    var btn=$(this);

    $("#m_student").text(btn.data("student"));
    $("#m_company").text(btn.data("company"));
    $("#m_job").text(btn.data("job"));
    $("#m_description").text(btn.data("description"));
    $("#m_location").text(btn.data("location"));
    $("#m_salary").text(btn.data("salary"));
    $("#m_jobtype").text(btn.data("jobtype"));

    $("#m_interviewtype").text(btn.data("interviewtype"));
    $("#m_date").text(btn.data("date"));
    $("#m_time").text(btn.data("time"));
    $("#m_lastdate").text(btn.data("lastdate"));
    $("#m_status").text(btn.data("status"));

    $("#m_photo").attr("src",btn.data("photo"));

    $("#interviewModal").modal("show");

    });

</script>