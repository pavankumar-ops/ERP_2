<!DOCTYPE html>
<html>
<head>
    <title>Test Creation</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

    <div class="container mt-4">

        <h4>ERP - Test Creation</h4>

        <div class="row mb-3">
            <div class="col-md-6">
                <label>Branch</label>
                <select id="branch" class="form-select">
                    <option value="">-- Select --</option>
                    <option>Computer Science</option>
                    <option>IT</option>
                </select>
            </div>

            <div class="col-md-6">
                <label>Test Name</label>
                <input type="text" id="testName" class="form-control">
            </div>
        </div>

        <hr />

        <h5>Question <span id="qNo">1</span></h5>

        <input type="text" id="question" class="form-control mb-2" placeholder="Question">

        <div class="row">
            <div class="col-md-6"><input id="optA" class="form-control mb-2" placeholder="Option A"></div>
            <div class="col-md-6"><input id="optB" class="form-control mb-2" placeholder="Option B"></div>
            <div class="col-md-6"><input id="optC" class="form-control mb-2" placeholder="Option C"></div>
            <div class="col-md-6"><input id="optD" class="form-control mb-2" placeholder="Option D"></div>
        </div>

        <select id="correct" class="form-select mb-3">
            <option value="">Correct Option</option>
            <option value="A">Option A</option>
            <option value="B">Option B</option>
            <option value="C">Option C</option>
            <option value="D">Option D</option>
        </select>

        <button class="btn btn-primary" onclick="addQuestion()">Next Question</button>
        <span class="ms-3">Added: <span id="count">0</span>/20</span>

        <hr />

        <button class="btn btn-success" onclick="submitTest()">Submit Test</button>
    </div>

    <script>
        let questions = [];

        function addQuestion() {

            if (questions.length >= 20) {
                alert("Only 20 questions allowed");
                return;
            }

            let q = question.value;
            let a = optA.value;
            let b = optB.value;
            let c = optC.value;
            let d = optD.value;
            let correctOpt = correct.value;

            if (!q || !a || !b || !c || !d || !correctOpt) {
                alert("Fill all fields");
                return;
            }

            questions.push({
                QuestionNo: questions.length + 1,
                Question: q,
                OptionA: a,
                OptionB: b,
                OptionC: c,
                OptionD: d,
                CorrectOption: correctOpt
            });

            count.innerText = questions.length;
            qNo.innerText = questions.length + 1;

            question.value = optA.value = optB.value = optC.value = optD.value = "";
            correct.value = "";
        }

        function submitTest() {

            if (questions.length !== 20) {
                alert("Exactly 20 questions required");
                return;
            }

            let model = {
                TestName: testName.value,
                Branch: branch.value,
                QuestionList: questions
            };

            fetch('/Trainer/SubmitTest', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(model)
            })
            .then(r => r.json())
            .then(d => {
                alert(d.message);
            });
        }
    </script>

</body>
</html>
